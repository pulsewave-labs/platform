# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Email / Resend
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM="PulseWave <hello@system.pulsewavelabs.io>"
SIGNAL_EMAIL_FROM="PulseWave <alerts@system.pulsewavelabs.io>"
EMAIL_REPLY_TO=hello@pulsewavelabs.io

# External APIs (optional)
COINGECKO_API_KEY=
CRYPTOCOMPARE_API_KEY=

# Stripe (if using payments)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Whop (if using checkout/webhooks)
WHOP_API_KEY=
WHOP_WEBHOOK_SECRET=
NEXT_PUBLIC_WHOP_COMPANY_ID=
NEXT_PUBLIC_WHOP_PLAN_ID_MONTHLY=
NEXT_PUBLIC_WHOP_PLAN_ID_YEARLY=
