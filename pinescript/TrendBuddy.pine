//@version=6
indicator('Trend Buddy', 'TrendBuddy', overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=50)

// ══════════════════════════════════════════════════════════════
// ██  INPUTS
// ══════════════════════════════════════════════════════════════

// ── Trend Engine ──
src           = input.source(close, 'Source', group='Trend Engine')
pivotLen      = input.int(5, 'Pivot Lookback', minval=2, maxval=20, group='Trend Engine', tooltip='Bars left/right for swing detection. Lower = more sensitive.')
adxLen        = input.int(14, 'ADX Length', minval=5, maxval=50, group='Trend Engine')
adxThresh     = input.float(20.0, 'ADX Trending Threshold', minval=10, maxval=40, step=1, group='Trend Engine', tooltip='Above this = trending. Below = ranging.')
emaFast       = input.int(8, 'Fast EMA', minval=3, maxval=50, group='Trend Engine')
emaMid        = input.int(21, 'Mid EMA', minval=5, maxval=100, group='Trend Engine')
emaSlow       = input.int(55, 'Slow EMA', minval=10, maxval=200, group='Trend Engine')

// ── Visual ──
showRibbon    = input.bool(true, 'Show EMA Ribbon', group='Visuals', inline='vis1')
showCandles   = input.bool(true, 'Color Candles', group='Visuals', inline='vis1')
showBG        = input.bool(true, 'Background Shading', group='Visuals', inline='vis2')
showArrows    = input.bool(true, 'Trend Change Arrows', group='Visuals', inline='vis2')
showDash      = input.bool(true, 'Dashboard', group='Visuals')
dashPos       = input.string('Top Right', 'Dashboard Position', options=['Top Right', 'Top Left', 'Bottom Right', 'Bottom Left'], group='Visuals')

// ── Colors ──
upColor       = input.color(#00e5a0, 'Uptrend', group='Colors', inline='col')
dnColor       = input.color(#ff4757, 'Downtrend', group='Colors', inline='col')
rgColor       = input.color(#808080, 'Ranging', group='Colors', inline='col')

// ── Multi-Timeframe ──
useMTF        = input.bool(false, 'Enable MTF Confluence', group='Multi-Timeframe')
tf2           = input.timeframe('60', 'Timeframe 2', group='Multi-Timeframe')
tf3           = input.timeframe('240', 'Timeframe 3', group='Multi-Timeframe')


// ══════════════════════════════════════════════════════════════
// ██  CORE CALCULATIONS
// ══════════════════════════════════════════════════════════════

// ── EMAs ──
ema8  = ta.ema(src, emaFast)
ema21 = ta.ema(src, emaMid)
ema55 = ta.ema(src, emaSlow)

// ── EMA Alignment Score ──
// +1 for each bullish alignment, -1 for bearish
emaScore = 0
emaScore := ema8 > ema21 ? emaScore + 1 : ema8 < ema21 ? emaScore - 1 : emaScore
emaScore := ema21 > ema55 ? emaScore + 1 : ema21 < ema55 ? emaScore - 1 : emaScore
emaScore := src > ema8 ? emaScore + 1 : src < ema8 ? emaScore - 1 : emaScore
// -3 to +3 range

// ── ADX + Directional Index ──
[diPlus, diMinus, adxVal] = ta.dmi(adxLen, adxLen)
isTrending = adxVal > adxThresh
adxBias    = diPlus > diMinus ? 1 : diPlus < diMinus ? -1 : 0

// ── Market Structure (Swing HH/HL/LH/LL) ──
swingHigh = ta.pivothigh(high, pivotLen, pivotLen)
swingLow  = ta.pivotlow(low, pivotLen, pivotLen)

var float lastSwingHigh  = na
var float prevSwingHigh  = na
var float lastSwingLow   = na
var float prevSwingLow   = na
var int   lastHighBar    = na
var int   lastLowBar     = na

if not na(swingHigh)
    prevSwingHigh := lastSwingHigh
    lastSwingHigh := swingHigh
    lastHighBar   := bar_index - pivotLen

if not na(swingLow)
    prevSwingLow := lastSwingLow
    lastSwingLow := swingLow
    lastLowBar   := bar_index - pivotLen

// Structure labels
bool isHH = not na(lastSwingHigh) and not na(prevSwingHigh) and lastSwingHigh > prevSwingHigh
bool isHL = not na(lastSwingLow) and not na(prevSwingLow) and lastSwingLow > prevSwingLow
bool isLH = not na(lastSwingHigh) and not na(prevSwingHigh) and lastSwingHigh < prevSwingHigh
bool isLL = not na(lastSwingLow) and not na(prevSwingLow) and lastSwingLow < prevSwingLow

// Structure score: +2 bullish, -2 bearish, 0 mixed/ranging
structScore = 0
structScore := isHH ? structScore + 1 : isLH ? structScore - 1 : structScore
structScore := isHL ? structScore + 1 : isLL ? structScore - 1 : structScore


// ══════════════════════════════════════════════════════════════
// ██  TREND CONSENSUS (3 voters)
// ══════════════════════════════════════════════════════════════

// Normalize each to -1, 0, +1
float v_ema    = emaScore >= 2 ? 1 : emaScore <= -2 ? -1 : 0
float v_adx    = isTrending ? adxBias : 0
float v_struct = structScore >= 2 ? 1 : structScore <= -2 ? -1 : 0

// Consensus: sum of votes (-3 to +3)
float consensus = v_ema + v_adx + v_struct

// Final trend state
var int trendState = 0  // 1=up, -1=down, 0=range
if consensus >= 2
    trendState := 1
else if consensus <= -2
    trendState := -1
else if math.abs(consensus) <= 1 and not isTrending
    trendState := 0
// else keep previous state (avoid flip-flopping on weak signals)

// Detect trend changes
int prevTrend   = trendState[1]
bool trendUp    = trendState == 1 and prevTrend != 1
bool trendDn    = trendState == -1 and prevTrend != -1
bool trendRange = trendState == 0 and prevTrend != 0

// Trend strength (0-100 scale)
float trendStrength = adxVal


// ══════════════════════════════════════════════════════════════
// ██  MULTI-TIMEFRAME CONFLUENCE
// ══════════════════════════════════════════════════════════════

f_trendCalc() =>
    e8  = ta.ema(close, emaFast)
    e21 = ta.ema(close, emaMid)
    e55 = ta.ema(close, emaSlow)
    es = 0
    es := e8 > e21 ? es + 1 : e8 < e21 ? es - 1 : es
    es := e21 > e55 ? es + 1 : e21 < e55 ? es - 1 : es
    es := close > e8 ? es + 1 : close < e8 ? es - 1 : es
    [dp, dm, ax] = ta.dmi(adxLen, adxLen)
    trending = ax > adxThresh
    bias = dp > dm ? 1 : dp < dm ? -1 : 0
    vEma = es >= 2 ? 1 : es <= -2 ? -1 : 0
    vAdx = trending ? bias : 0
    con = vEma + vAdx
    state = con >= 2 ? 1 : con <= -2 ? -1 : 0
    [state, ax]

[tf2State, tf2Adx] = request.security(syminfo.tickerid, tf2, f_trendCalc())
[tf3State, tf3Adx] = request.security(syminfo.tickerid, tf3, f_trendCalc())

// MTF alignment bonus
float mtfScore = 0
if useMTF
    mtfScore := (tf2State == trendState ? 1 : 0) + (tf3State == trendState ? 1 : 0)


// ══════════════════════════════════════════════════════════════
// ██  VISUALS
// ══════════════════════════════════════════════════════════════

// ── Trend Color ──
trendCol = trendState == 1 ? upColor : trendState == -1 ? dnColor : rgColor

// ── EMA Ribbon ──
p1 = plot(showRibbon ? ema8  : na, 'Fast EMA', color=color.new(trendCol, 30), linewidth=1)
p2 = plot(showRibbon ? ema21 : na, 'Mid EMA',  color=color.new(trendCol, 50), linewidth=1)
p3 = plot(showRibbon ? ema55 : na, 'Slow EMA', color=color.new(trendCol, 70), linewidth=2)

fill(p1, p2, color=color.new(trendCol, 85), title='Ribbon Fill 1')
fill(p2, p3, color=color.new(trendCol, 92), title='Ribbon Fill 2')

// ── Candle Coloring ──
barcolor(showCandles ? trendCol : na)

// ── Background ──
bgcolor(showBG ? color.new(trendCol, 95) : na, title='Trend Background')

// ── Trend Change Arrows ──
plotshape(showArrows and trendUp, 'Uptrend Start', shape.triangleup, location.belowbar, upColor, size=size.small)
plotshape(showArrows and trendDn, 'Downtrend Start', shape.triangledown, location.abovebar, dnColor, size=size.small)
plotshape(showArrows and trendRange, 'Range Start', shape.diamond, location.abovebar, rgColor, size=size.tiny)

// ── Swing Markers (subtle) ──
plotshape(not na(swingHigh), 'Swing High', shape.circle, location.abovebar, color.new(trendCol, 60), size=size.auto)
plotshape(not na(swingLow), 'Swing Low', shape.circle, location.belowbar, color.new(trendCol, 60), size=size.auto)


// ══════════════════════════════════════════════════════════════
// ██  DASHBOARD
// ══════════════════════════════════════════════════════════════

if showDash and barstate.islast
    dashX = dashPos == 'Top Right' or dashPos == 'Bottom Right' ? position.top_right : dashPos == 'Top Left' or dashPos == 'Bottom Left' ? position.top_left : position.top_right
    if dashPos == 'Bottom Right'
        dashX := position.bottom_right
    if dashPos == 'Bottom Left'
        dashX := position.bottom_left

    var tbl = table.new(dashX, 5, 7, bgcolor=color.new(#0a0a0c, 10), border_color=color.new(color.white, 85), border_width=1, frame_color=color.new(color.white, 85), frame_width=1)

    // Header
    table.cell(tbl, 0, 0, 'TREND BUDDY', text_color=color.white, text_size=size.small, bgcolor=color.new(#0a0a0c, 0))
    table.merge_cells(tbl, 0, 0, 4, 0)

    // Column headers
    table.cell(tbl, 0, 1, 'TF', text_color=color.new(color.white, 40), text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))
    table.cell(tbl, 1, 1, 'Trend', text_color=color.new(color.white, 40), text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))
    table.cell(tbl, 2, 1, 'Strength', text_color=color.new(color.white, 40), text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))
    table.cell(tbl, 3, 1, 'EMA', text_color=color.new(color.white, 40), text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))
    table.cell(tbl, 4, 1, 'Structure', text_color=color.new(color.white, 40), text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))

    // Current TF row
    string trendLabel = trendState == 1 ? '▲ UPTREND' : trendState == -1 ? '▼ DOWNTREND' : '◆ RANGING'
    string strLabel   = adxVal > 40 ? 'STRONG' : adxVal > adxThresh ? 'MODERATE' : 'WEAK'
    string emaLabel   = v_ema > 0 ? 'BULLISH' : v_ema < 0 ? 'BEARISH' : 'MIXED'
    string structLabel = v_struct > 0 ? 'HH/HL' : v_struct < 0 ? 'LH/LL' : 'MIXED'
    color  strColor   = adxVal > 40 ? upColor : adxVal > adxThresh ? color.new(upColor, 40) : rgColor

    table.cell(tbl, 0, 2, timeframe.period, text_color=color.white, text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))
    table.cell(tbl, 1, 2, trendLabel, text_color=trendCol, text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))
    table.cell(tbl, 2, 2, strLabel + ' (' + str.tostring(adxVal, '#.#') + ')', text_color=strColor, text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))
    table.cell(tbl, 3, 2, emaLabel, text_color=v_ema > 0 ? upColor : v_ema < 0 ? dnColor : rgColor, text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))
    table.cell(tbl, 4, 2, structLabel, text_color=v_struct > 0 ? upColor : v_struct < 0 ? dnColor : rgColor, text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))

    // MTF rows
    if useMTF
        string tf2Label = tf2State == 1 ? '▲ UP' : tf2State == -1 ? '▼ DOWN' : '◆ RANGE'
        color  tf2Col   = tf2State == 1 ? upColor : tf2State == -1 ? dnColor : rgColor
        table.cell(tbl, 0, 3, tf2, text_color=color.white, text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))
        table.cell(tbl, 1, 3, tf2Label, text_color=tf2Col, text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))
        table.cell(tbl, 2, 3, str.tostring(tf2Adx, '#.#'), text_color=tf2Adx > adxThresh ? upColor : rgColor, text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))
        table.cell(tbl, 3, 3, '', text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))
        table.cell(tbl, 4, 3, '', text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))

        string tf3Label = tf3State == 1 ? '▲ UP' : tf3State == -1 ? '▼ DOWN' : '◆ RANGE'
        color  tf3Col   = tf3State == 1 ? upColor : tf3State == -1 ? dnColor : rgColor
        table.cell(tbl, 0, 4, tf3, text_color=color.white, text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))
        table.cell(tbl, 1, 4, tf3Label, text_color=tf3Col, text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))
        table.cell(tbl, 2, 4, str.tostring(tf3Adx, '#.#'), text_color=tf3Adx > adxThresh ? upColor : rgColor, text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))
        table.cell(tbl, 3, 4, '', text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))
        table.cell(tbl, 4, 4, '', text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))

    // Confluence row
    if useMTF
        bool allAligned = tf2State == trendState and tf3State == trendState and trendState != 0
        string confLabel = allAligned ? '✓ ALL ALIGNED' : 'MIXED'
        color  confCol   = allAligned ? upColor : rgColor
        table.cell(tbl, 0, 5, '', text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))
        table.cell(tbl, 1, 5, confLabel, text_color=confCol, text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))
        table.merge_cells(tbl, 1, 5, 4, 5)


// ══════════════════════════════════════════════════════════════
// ██  ALERTS
// ══════════════════════════════════════════════════════════════

alertcondition(trendUp, 'Uptrend Started', '🟢 {{ticker}} Uptrend started on {{interval}}')
alertcondition(trendDn, 'Downtrend Started', '🔴 {{ticker}} Downtrend started on {{interval}}')
alertcondition(trendRange, 'Ranging Started', '⚪ {{ticker}} entered ranging on {{interval}}')
alertcondition(trendUp or trendDn, 'Any Trend Change', '⚡ {{ticker}} trend changed on {{interval}}')
