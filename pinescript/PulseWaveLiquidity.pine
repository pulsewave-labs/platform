//@version=6
indicator('PulseWave Liquidity', 'PW-Liq', overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=500)

// ══════════════════════════════════════════════════════════════
// ██  PULSEWAVE LIQUIDITY — Where the Money Gets Taken
// ══════════════════════════════════════════════════════════════
//
// TradingView can't see order books. But we can CALCULATE where
// liquidations cluster based on swing points + common leverage.
//
// When price makes a swing high → longs entered there.
//   Their liquidations are BELOW at: price × (1 - 1/leverage)
//
// When price makes a swing low → shorts entered there.
//   Their liquidations are ABOVE at: price × (1 + 1/leverage)
//
// Volume at the swing = how many positions = how thick the
// liquidation cluster is.
//
// Price is a magnet for liquidity. It WILL hunt these levels.
//
// ══════════════════════════════════════════════════════════════


// ── Inputs ──────────────────────────────────────────────────
pivotLen     = input.int(5, 'Swing Lookback', minval=2, maxval=20, group='Detection', tooltip='Bars left/right for swing detection. Lower = more levels, more noise.')
maxSwings    = input.int(15, 'Max Active Swings', minval=5, maxval=50, group='Detection', tooltip='How many recent swing points to track liquidation levels from.')
pruneATR     = input.float(0.5, 'Prune Distance (ATR)', minval=0.1, maxval=3.0, step=0.1, group='Detection', tooltip='Remove levels closer than this × ATR to reduce clutter.')

// Leverage levels to show
show100x     = input.bool(true, '100× Liquidations', group='Leverage Levels', inline='lev1')
show50x      = input.bool(true, '50× Liquidations', group='Leverage Levels', inline='lev1')
show25x      = input.bool(true, '25× Liquidations', group='Leverage Levels', inline='lev2')
show10x      = input.bool(true, '10× Liquidations', group='Leverage Levels', inline='lev2')
show5x       = input.bool(false, '5× Liquidations', group='Leverage Levels', inline='lev3')
show3x       = input.bool(false, '3× Liquidations', group='Leverage Levels', inline='lev3')

// Visuals
showZones    = input.bool(true, 'Liquidation Zones', group='Visuals', tooltip='Draw boxes around liquidation clusters.')
showLines    = input.bool(true, 'Level Lines', group='Visuals')
showLabels   = input.bool(true, 'Labels', group='Visuals')
showSwings   = input.bool(true, 'Swing Markers', group='Visuals')
showDash     = input.bool(true, 'Dashboard', group='Visuals')
zoneWidth    = input.float(0.15, 'Zone Width %', minval=0.05, maxval=1.0, step=0.05, group='Visuals', tooltip='Width of liquidation zone boxes as % of price.')

// Colors
longLiqCol   = input.color(#ff4757, 'Long Liquidations (below)', group='Colors', tooltip='Where longs get liquidated — below swing lows.')
shortLiqCol  = input.color(#00e5a0, 'Short Liquidations (above)', group='Colors', tooltip='Where shorts get liquidated — above swing highs.')
huntedCol    = input.color(#ffaa00, 'Hunted Level', group='Colors')

// Volume weighting
useVolWeight = input.bool(true, 'Volume-Weighted Levels', group='Volume', tooltip='Thicker levels where more volume traded at the swing = more liquidations sitting there.')
volLen       = input.int(20, 'Volume MA Length', minval=5, maxval=50, group='Volume')


// ══════════════════════════════════════════════════════════════
// ██  CORE CALCULATIONS
// ══════════════════════════════════════════════════════════════

atrVal = ta.atr(14)
volMA  = ta.sma(volume, volLen)

// Detect swing highs and lows
swingHigh = ta.pivothigh(high, pivotLen, pivotLen)
swingLow  = ta.pivotlow(low, pivotLen, pivotLen)

// ── Leverage math ──
// Long liquidation: entry - (entry / leverage) = entry × (1 - 1/lev)
// Short liquidation: entry + (entry / leverage) = entry × (1 + 1/lev)

f_longLiqPrice(entry, lev) =>
    entry * (1.0 - 1.0 / lev)

f_shortLiqPrice(entry, lev) =>
    entry * (1.0 + 1.0 / lev)


// ══════════════════════════════════════════════════════════════
// ██  SWING TRACKING + LIQUIDATION LEVELS
// ══════════════════════════════════════════════════════════════

// Arrays to store swing data
var float[] swingHighPrices = array.new_float()
var int[]   swingHighBars   = array.new_int()
var float[] swingHighVols   = array.new_float()
var float[] swingLowPrices  = array.new_float()
var int[]   swingLowBars    = array.new_int()
var float[] swingLowVols    = array.new_float()

// Track hunted levels
var float[] huntedLevels    = array.new_float()

// Store new swing highs
if not na(swingHigh)
    array.unshift(swingHighPrices, swingHigh)
    array.unshift(swingHighBars, bar_index - pivotLen)
    // Volume at swing = sum of volume around the pivot
    swingVol = 0.0
    for i = 0 to pivotLen * 2
        swingVol += nz(volume[i])
    array.unshift(swingHighVols, swingVol)
    // Cap array size
    if array.size(swingHighPrices) > maxSwings
        array.pop(swingHighPrices)
        array.pop(swingHighBars)
        array.pop(swingHighVols)

// Store new swing lows
if not na(swingLow)
    array.unshift(swingLowPrices, swingLow)
    array.unshift(swingLowBars, bar_index - pivotLen)
    swingVol = 0.0
    for i = 0 to pivotLen * 2
        swingVol += nz(volume[i])
    array.unshift(swingLowVols, swingVol)
    if array.size(swingLowPrices) > maxSwings
        array.pop(swingLowPrices)
        array.pop(swingLowBars)
        array.pop(swingLowVols)


// ══════════════════════════════════════════════════════════════
// ██  LIQUIDATION LEVEL COMPUTATION
// ══════════════════════════════════════════════════════════════

// Leverage multipliers to calculate
var float[] leverages = array.from(100.0, 50.0, 25.0, 10.0, 5.0, 3.0)
var bool[] levEnabled = array.from(show100x, show50x, show25x, show10x, show5x, show3x)

// Structure to hold computed levels for drawing
var float[] liqLevels     = array.new_float()
var int[]   liqTypes      = array.new_int()     // 1=short liq (above highs), -1=long liq (below lows)
var float[] liqStrengths  = array.new_float()    // volume-weighted strength 0-1
var int[]   liqLevBars    = array.new_int()       // bar_index of source swing
var float[] liqLevLev     = array.new_float()     // leverage value
var bool[]  liqHunted     = array.new_bool()      // whether price already swept this level

// Recompute every bar
array.clear(liqLevels)
array.clear(liqTypes)
array.clear(liqStrengths)
array.clear(liqLevBars)
array.clear(liqLevLev)
array.clear(liqHunted)

// Max volume for normalization
float maxVol = 0.0
int _maxVolLen = math.max(array.size(swingHighVols), array.size(swingLowVols))
if _maxVolLen > 0
    for i = 0 to _maxVolLen - 1
        if i < array.size(swingHighVols)
            maxVol := math.max(maxVol, array.get(swingHighVols, i))
        if i < array.size(swingLowVols)
            maxVol := math.max(maxVol, array.get(swingLowVols, i))

// From swing HIGHS → SHORT liquidation levels (above)
// Shorts entered at swing highs, their liquidations are above
int _shSize = array.size(swingHighPrices)
if _shSize > 0
    for i = 0 to _shSize - 1
        entry = array.get(swingHighPrices, i)
        srcBar = array.get(swingHighBars, i)
        vol = array.get(swingHighVols, i)
        strength = maxVol > 0 ? vol / maxVol : 0.5
        for j = 0 to array.size(leverages) - 1
            if array.get(levEnabled, j)
                lev = array.get(leverages, j)
                liqPrice = f_shortLiqPrice(entry, lev)
                if math.abs(liqPrice - close) / close < 0.25
                    hunted = high >= liqPrice and srcBar < bar_index
                    array.push(liqLevels, liqPrice)
                    array.push(liqTypes, 1)
                    array.push(liqStrengths, strength)
                    array.push(liqLevBars, srcBar)
                    array.push(liqLevLev, lev)
                    array.push(liqHunted, hunted)

// From swing LOWS → LONG liquidation levels (below)
// Longs entered at swing lows, their liquidations are below
int _slSize = array.size(swingLowPrices)
if _slSize > 0
    for i = 0 to _slSize - 1
        entry = array.get(swingLowPrices, i)
        srcBar = array.get(swingLowBars, i)
        vol = array.get(swingLowVols, i)
        strength = maxVol > 0 ? vol / maxVol : 0.5
        for j = 0 to array.size(leverages) - 1
            if array.get(levEnabled, j)
                lev = array.get(leverages, j)
                liqPrice = f_longLiqPrice(entry, lev)
                if math.abs(liqPrice - close) / close < 0.25
                    hunted = low <= liqPrice and srcBar < bar_index
                    array.push(liqLevels, liqPrice)
                    array.push(liqTypes, -1)
                    array.push(liqStrengths, strength)
                    array.push(liqLevBars, srcBar)
                    array.push(liqLevLev, lev)
                    array.push(liqHunted, hunted)


// ══════════════════════════════════════════════════════════════
// ██  CLUSTER DETECTION
// ══════════════════════════════════════════════════════════════
// When multiple liquidation levels from different leverages/swings
// converge in a tight zone = MEGA LIQUIDITY CLUSTER
// These are the highest-probability targets for price

var float[] clusterPrices    = array.new_float()
var float[] clusterStrengths = array.new_float()
var int[]   clusterTypes     = array.new_int()
var int[]   clusterCounts    = array.new_int()

array.clear(clusterPrices)
array.clear(clusterStrengths)
array.clear(clusterTypes)
array.clear(clusterCounts)

int _liqSize = array.size(liqLevels)
if _liqSize > 0
    used = array.new_bool(_liqSize, false)
    for i = 0 to _liqSize - 1
        if not array.get(used, i) and not array.get(liqHunted, i)
            clusterPrice = array.get(liqLevels, i)
            clusterStr   = array.get(liqStrengths, i)
            clusterType  = array.get(liqTypes, i)
            count        = 1
            if i + 1 <= _liqSize - 1
                for j = i + 1 to _liqSize - 1
                    if not array.get(used, j) and not array.get(liqHunted, j)
                        if math.abs(array.get(liqLevels, j) - clusterPrice) < atrVal * pruneATR
                            clusterPrice := (clusterPrice * count + array.get(liqLevels, j)) / (count + 1)
                            clusterStr   := clusterStr + array.get(liqStrengths, j)
                            count        += 1
                            array.set(used, j, true)
            array.push(clusterPrices, clusterPrice)
            array.push(clusterStrengths, math.min(clusterStr, 5.0))
            array.push(clusterTypes, clusterType)
            array.push(clusterCounts, count)


// ══════════════════════════════════════════════════════════════
// ██  DRAWING
// ══════════════════════════════════════════════════════════════

// Clean previous drawings
var line[]  drawnLines  = array.new_line()
var label[] drawnLabels = array.new_label()
var box[]   drawnBoxes  = array.new_box()

if barstate.islast
    // Clear old drawings
    if array.size(drawnLines) > 0
        for i = 0 to array.size(drawnLines) - 1
            line.delete(array.get(drawnLines, i))
    array.clear(drawnLines)
    if array.size(drawnLabels) > 0
        for i = 0 to array.size(drawnLabels) - 1
            label.delete(array.get(drawnLabels, i))
    array.clear(drawnLabels)
    if array.size(drawnBoxes) > 0
        for i = 0 to array.size(drawnBoxes) - 1
            box.delete(array.get(drawnBoxes, i))
    array.clear(drawnBoxes)

    // Draw swing markers
    if showSwings and array.size(swingHighPrices) > 0
        for i = 0 to array.size(swingHighPrices) - 1
            lbl = label.new(array.get(swingHighBars, i), array.get(swingHighPrices, i), '◆', style=label.style_none, textcolor=color.new(shortLiqCol, 50), size=size.tiny)
            array.push(drawnLabels, lbl)
    if showSwings and array.size(swingLowPrices) > 0
        for i = 0 to array.size(swingLowPrices) - 1
            lbl = label.new(array.get(swingLowBars, i), array.get(swingLowPrices, i), '◆', style=label.style_none, textcolor=color.new(longLiqCol, 50), size=size.tiny)
            array.push(drawnLabels, lbl)

    // Draw clusters (the main output)
    maxClusterStr = 1.0
    int _csSize = array.size(clusterStrengths)
    if _csSize > 0
        for i = 0 to _csSize - 1
            maxClusterStr := math.max(maxClusterStr, array.get(clusterStrengths, i))

    int _cpSize = array.size(clusterPrices)
    if _cpSize > 0
        for i = 0 to _cpSize - 1
            price    = array.get(clusterPrices, i)
            str2     = array.get(clusterStrengths, i)
            type     = array.get(clusterTypes, i)
            count    = array.get(clusterCounts, i)
            normStr  = str2 / maxClusterStr
            baseCol  = type == 1 ? shortLiqCol : longLiqCol
            alpha    = math.round(math.max(80 - normStr * 60, 20))
            halfWidth = price * zoneWidth / 100 * (0.5 + normStr * 0.5)
            if showLines
                lineWidth = normStr > 0.7 ? 2 : 1
                ln = line.new(bar_index - 40, price, bar_index + 20, price, color=color.new(baseCol, alpha), width=lineWidth, style=normStr > 0.5 ? line.style_solid : line.style_dotted)
                array.push(drawnLines, ln)
            if showZones and normStr > 0.3
                zoneAlpha = math.round(math.max(95 - normStr * 15, 80))
                bx = box.new(bar_index - 30, price + halfWidth, bar_index + 20, price - halfWidth, bgcolor=color.new(baseCol, zoneAlpha), border_color=color.new(baseCol, alpha), border_width=1)
                array.push(drawnBoxes, bx)
            if showLabels
                levText = count > 2 ? '🧲 CLUSTER ×' + str.tostring(count) : type == 1 ? 'SHORT LIQ' : 'LONG LIQ'
                priceText = str.tostring(price, '#.#')
                distPct = (price - close) / close * 100
                distText = (distPct > 0 ? '+' : '') + str.tostring(distPct, '#.##') + '%'
                lbl = label.new(bar_index + 22, price, levText + '\n' + priceText + ' (' + distText + ')', style=label.style_label_left, color=color.new(baseCol, 90), textcolor=color.new(baseCol, math.round(math.max(alpha - 20, 0))), size=size.tiny)
                array.push(drawnLabels, lbl)


    // ══════════════════════════════════════════════════════════
    // ██  NEAREST LIQUIDITY TARGETS
    // ══════════════════════════════════════════════════════════
    
    float nearestAbove     = na
    float nearestAboveStr  = 0
    int   nearestAboveCnt  = 0
    float nearestBelow     = na
    float nearestBelowStr  = 0
    int   nearestBelowCnt  = 0

    if _cpSize > 0
        for i = 0 to _cpSize - 1
            price = array.get(clusterPrices, i)
            str3  = array.get(clusterStrengths, i)
            cnt   = array.get(clusterCounts, i)
            if price > close
                if na(nearestAbove) or price < nearestAbove
                    nearestAbove    := price
                    nearestAboveStr := str3
                    nearestAboveCnt := cnt
            else if price < close
                if na(nearestBelow) or price > nearestBelow
                    nearestBelow    := price
                    nearestBelowStr := str3
                    nearestBelowCnt := cnt


    // ══════════════════════════════════════════════════════════
    // ██  DASHBOARD
    // ══════════════════════════════════════════════════════════

    if showDash
        var tbl = table.new(position.top_right, 2, 9, bgcolor=color.new(#0a0a0c, 5), border_color=color.new(color.white, 90), border_width=1, frame_color=color.new(color.white, 85), frame_width=1)

        table.cell(tbl, 0, 0, '  PW LIQUIDITY  ', text_color=#00e5a0, text_size=size.small, bgcolor=color.new(#0a0a0c, 0))
        table.merge_cells(tbl, 0, 0, 1, 0)

        // Active levels
        table.cell(tbl, 0, 1, 'Active Clusters', text_color=color.new(color.white, 40), text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))
        table.cell(tbl, 1, 1, str.tostring(array.size(clusterPrices)), text_color=color.white, text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))

        // Nearest above (short liquidations — target for price moving up)
        table.cell(tbl, 0, 2, '▲ Above', text_color=color.new(color.white, 40), text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))
        if not na(nearestAbove)
            aboveDist = (nearestAbove - close) / close * 100
            aboveText = '$' + str.tostring(nearestAbove, '#') + ' (+' + str.tostring(aboveDist, '#.##') + '%)'
            table.cell(tbl, 1, 2, aboveText, text_color=shortLiqCol, text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))
        else
            table.cell(tbl, 1, 2, '—', text_color=color.new(color.white, 20), text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))

        // Above strength
        table.cell(tbl, 0, 3, '  Strength', text_color=color.new(color.white, 20), text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))
        aboveStrText = nearestAboveCnt > 2 ? '🧲 MEGA (' + str.tostring(nearestAboveCnt) + ' levels)' : nearestAboveCnt > 1 ? 'STRONG (' + str.tostring(nearestAboveCnt) + ' levels)' : nearestAboveCnt == 1 ? 'SINGLE' : '—'
        table.cell(tbl, 1, 3, aboveStrText, text_color=nearestAboveCnt > 2 ? huntedCol : color.new(color.white, 40), text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))

        // Nearest below (long liquidations — target for price moving down)
        table.cell(tbl, 0, 4, '▼ Below', text_color=color.new(color.white, 40), text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))
        if not na(nearestBelow)
            belowDist = (nearestBelow - close) / close * 100
            belowText = '$' + str.tostring(nearestBelow, '#') + ' (' + str.tostring(belowDist, '#.##') + '%)'
            table.cell(tbl, 1, 4, belowText, text_color=longLiqCol, text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))
        else
            table.cell(tbl, 1, 4, '—', text_color=color.new(color.white, 20), text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))

        // Below strength
        table.cell(tbl, 0, 5, '  Strength', text_color=color.new(color.white, 20), text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))
        belowStrText = nearestBelowCnt > 2 ? '🧲 MEGA (' + str.tostring(nearestBelowCnt) + ' levels)' : nearestBelowCnt > 1 ? 'STRONG (' + str.tostring(nearestBelowCnt) + ' levels)' : nearestBelowCnt == 1 ? 'SINGLE' : '—'
        table.cell(tbl, 1, 5, belowStrText, text_color=nearestBelowCnt > 2 ? huntedCol : color.new(color.white, 40), text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))

        // Bias
        table.cell(tbl, 0, 6, 'Magnet', text_color=color.new(color.white, 40), text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))
        biasText = na(nearestAbove) and na(nearestBelow) ? 'NO DATA' : na(nearestAbove) ? '▼ BELOW' : na(nearestBelow) ? '▲ ABOVE' : nearestAboveStr > nearestBelowStr * 1.5 ? '▲ MORE LIQ ABOVE' : nearestBelowStr > nearestAboveStr * 1.5 ? '▼ MORE LIQ BELOW' : '↔ BALANCED'
        biasCol = na(nearestAbove) and na(nearestBelow) ? color.new(color.white, 40) : na(nearestAbove) ? longLiqCol : na(nearestBelow) ? shortLiqCol : nearestAboveStr > nearestBelowStr * 1.5 ? shortLiqCol : nearestBelowStr > nearestAboveStr * 1.5 ? longLiqCol : huntedCol
        table.cell(tbl, 1, 6, biasText, text_color=biasCol, text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))

        // Swing sources
        table.cell(tbl, 0, 7, 'Swing Highs', text_color=color.new(color.white, 20), text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))
        table.cell(tbl, 1, 7, str.tostring(array.size(swingHighPrices)), text_color=color.new(color.white, 30), text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))
        table.cell(tbl, 0, 8, 'Swing Lows', text_color=color.new(color.white, 20), text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))
        table.cell(tbl, 1, 8, str.tostring(array.size(swingLowPrices)), text_color=color.new(color.white, 30), text_size=size.tiny, bgcolor=color.new(#0a0a0c, 0))


// ══════════════════════════════════════════════════════════════
// ██  ALERTS
// ══════════════════════════════════════════════════════════════

// Simple proximity alerts
var float prevNearAbove = na
var float prevNearBelow = na

// Track nearest for alerting (computed each bar, not just last)
float barNearAbove = na
float barNearBelow = na

if array.size(clusterPrices) > 0
    for i = 0 to array.size(clusterPrices) - 1
        p = array.get(clusterPrices, i)
        if p > close and (na(barNearAbove) or p < barNearAbove)
            barNearAbove := p
        if p < close and (na(barNearBelow) or p > barNearBelow)
            barNearBelow := p

// Price approaching liquidity (within 0.5%)
bool approachingAbove = not na(barNearAbove) and (barNearAbove - close) / close < 0.005
bool approachingBelow = not na(barNearBelow) and (close - barNearBelow) / close < 0.005

// Price swept liquidity
bool sweptAbove = not na(barNearAbove) and high >= barNearAbove
bool sweptBelow = not na(barNearBelow) and low <= barNearBelow

alertcondition(approachingAbove, 'Approaching Liq Above', '⚡ {{ticker}} approaching short liquidation cluster at {{close}} on {{interval}}')
alertcondition(approachingBelow, 'Approaching Liq Below', '⚡ {{ticker}} approaching long liquidation cluster at {{close}} on {{interval}}')
alertcondition(sweptAbove, 'Swept Liq Above', '💥 {{ticker}} swept short liquidations above — possible reversal on {{interval}}')
alertcondition(sweptBelow, 'Swept Liq Below', '💥 {{ticker}} swept long liquidations below — possible reversal on {{interval}}')
