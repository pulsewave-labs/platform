// This Pine Script™ code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// © PulseWave Labs
// Zone rendering via plot() + fill() — scales with chart by definition

//@version=6
indicator('PulseWave Zones', 'PW Zones', overlay=true, max_labels_count=500, max_boxes_count=0, max_lines_count=0)

// ──────────────────────────────────────────────────────────────
// SETUP
// ──────────────────────────────────────────────────────────────
prd        = input.int(defval=10, title='Pivot Period', minval=4, maxval=30, group='Setup')
ppsrc      = input.string(defval='High/Low', title='Source', options=['High/Low', 'Close/Open'], group='Setup')
maxnumpp   = input.int(defval=60, title='Maximum Pivots', minval=5, maxval=200, group='Setup')
ChannelW   = input.int(defval=10, title='Max Channel Width %', minval=1, maxval=50, group='Setup')
maxnumsr   = input.int(defval=8, title='Max S/R Levels', minval=1, maxval=15, group='Setup')
min_strength = input.int(defval=3, title='Min Strength', minval=1, maxval=10, group='Setup')
cwLookback = input.int(defval=400, title='Lookback Period', minval=50, maxval=1000, group='Setup')

// ──────────────────────────────────────────────────────────────
// TIMEFRAMES
// ──────────────────────────────────────────────────────────────
useTF1      = input.bool(defval=true, title='Enable', group='Timeframe 1')
tf1         = input.timeframe(defval='30', title='Timeframe', group='Timeframe 1')
tf1ResColor = input.color(defval=color.rgb(255, 73, 118), title='Resistance Color', group='Timeframe 1')
tf1SupColor = input.color(defval=color.rgb(0, 229, 160), title='Support Color', group='Timeframe 1')

useTF2      = input.bool(defval=false, title='Enable', group='Timeframe 2')
tf2         = input.timeframe(defval='240', title='Timeframe', group='Timeframe 2')
tf2ResColor = input.color(defval=color.rgb(255, 140, 0), title='Resistance Color', group='Timeframe 2')
tf2SupColor = input.color(defval=color.rgb(0, 180, 220), title='Support Color', group='Timeframe 2')

// ──────────────────────────────────────────────────────────────
// DISPLAY
// ──────────────────────────────────────────────────────────────
showLabels   = input.bool(defval=true, title='Show Labels', group='Display')
showStrength = input.bool(defval=true, title='Show Strength', group='Display')
labelloc     = input.int(defval=20, title='Label Offset', group='Display')
zoneTransp   = input.int(defval=88, title='Zone Fill Transparency', minval=50, maxval=98, group='Display')

// ──────────────────────────────────────────────────────────────
// ALERTS
// ──────────────────────────────────────────────────────────────
alertProximity = input.bool(defval=false, title='Proximity Alerts', group='Alerts')
proximityPct   = input.float(defval=0.5, title='Proximity %', minval=0.1, maxval=5.0, step=0.1, group='Alerts')

// ──────────────────────────────────────────────────────────────
// UTILITIES
// ──────────────────────────────────────────────────────────────
tfLabel(tf) =>
    tf == '1' ? '1m' : tf == '3' ? '3m' : tf == '5' ? '5m' : tf == '15' ? '15m' : tf == '30' ? '30m' : tf == '60' ? '1H' : tf == '120' ? '2H' : tf == '240' ? '4H' : tf == '480' ? '8H' : tf == 'D' ? '1D' : tf == 'W' ? '1W' : tf == 'M' ? '1M' : tf

// ──────────────────────────────────────────────────────────────
// S/R ENGINE — V1.1 exact algorithm
// ──────────────────────────────────────────────────────────────
calcSR() =>
    float _src1 = ppsrc == 'High/Low' ? high : math.max(close, open)
    float _src2 = ppsrc == 'High/Low' ? low : math.min(close, open)
    float _ph = ta.pivothigh(_src1, prd, prd)
    float _pl = ta.pivotlow(_src2, prd, prd)

    var _pvt = array.new_float(0)
    if not na(_ph) or not na(_pl)
        array.unshift(_pvt, not na(_ph) ? _ph : _pl)
        if array.size(_pvt) > maxnumpp
            array.pop(_pvt)

    float _highest = ta.highest(cwLookback)
    float _lowest  = ta.lowest(cwLookback)
    float _cw = (_highest - _lowest) * ChannelW / 100

    var _sr_hi = array.new_float(0)
    var _sr_lo = array.new_float(0)
    var _sr_st = array.new_float(0)

    if not na(_ph) or not na(_pl)
        array.clear(_sr_hi)
        array.clear(_sr_lo)
        array.clear(_sr_st)
        for i = 0 to array.size(_pvt) - 1
            float _ilo = array.get(_pvt, i)
            float _ihi = _ilo
            int _numpp = 0
            for j = 0 to array.size(_pvt) - 1
                float _cpp = array.get(_pvt, j)
                float _wdth = _cpp <= _ilo ? _ihi - _cpp : _cpp - _ilo
                if _wdth <= _cw
                    if _cpp <= _ihi
                        _ilo := math.min(_ilo, _cpp)
                    else
                        _ihi := math.max(_ihi, _cpp)
                    _numpp += 1
            bool _valid = true
            for k = 0 to array.size(_sr_hi) > 0 ? array.size(_sr_hi) - 1 : na
                if array.get(_sr_hi, k) >= _ilo and array.get(_sr_hi, k) <= _ihi or array.get(_sr_lo, k) >= _ilo and array.get(_sr_lo, k) <= _ihi
                    if _numpp >= array.get(_sr_st, k)
                        array.remove(_sr_hi, k)
                        array.remove(_sr_lo, k)
                        array.remove(_sr_st, k)
                    else
                        _valid := false
                    break
            if _valid and _numpp >= min_strength
                int _loc = array.size(_sr_st)
                for m = _loc > 0 ? array.size(_sr_st) - 1 : na to 0
                    if _numpp <= array.get(_sr_st, m)
                        break
                    _loc := m
                if _loc < maxnumsr
                    array.insert(_sr_hi, _loc, _ihi)
                    array.insert(_sr_lo, _loc, _ilo)
                    array.insert(_sr_st, _loc, _numpp)
                    if array.size(_sr_st) > maxnumsr
                        array.pop(_sr_st)
                        array.pop(_sr_hi)
                        array.pop(_sr_lo)

    float _m0 = array.size(_sr_hi) > 0 ? math.round_to_mintick((array.get(_sr_hi, 0) + array.get(_sr_lo, 0)) / 2) : na
    float _m1 = array.size(_sr_hi) > 1 ? math.round_to_mintick((array.get(_sr_hi, 1) + array.get(_sr_lo, 1)) / 2) : na
    float _m2 = array.size(_sr_hi) > 2 ? math.round_to_mintick((array.get(_sr_hi, 2) + array.get(_sr_lo, 2)) / 2) : na
    float _m3 = array.size(_sr_hi) > 3 ? math.round_to_mintick((array.get(_sr_hi, 3) + array.get(_sr_lo, 3)) / 2) : na
    float _m4 = array.size(_sr_hi) > 4 ? math.round_to_mintick((array.get(_sr_hi, 4) + array.get(_sr_lo, 4)) / 2) : na
    float _h0 = array.size(_sr_hi) > 0 ? array.get(_sr_hi, 0) : na
    float _h1 = array.size(_sr_hi) > 1 ? array.get(_sr_hi, 1) : na
    float _h2 = array.size(_sr_hi) > 2 ? array.get(_sr_hi, 2) : na
    float _h3 = array.size(_sr_hi) > 3 ? array.get(_sr_hi, 3) : na
    float _h4 = array.size(_sr_hi) > 4 ? array.get(_sr_hi, 4) : na
    float _l0 = array.size(_sr_lo) > 0 ? array.get(_sr_lo, 0) : na
    float _l1 = array.size(_sr_lo) > 1 ? array.get(_sr_lo, 1) : na
    float _l2 = array.size(_sr_lo) > 2 ? array.get(_sr_lo, 2) : na
    float _l3 = array.size(_sr_lo) > 3 ? array.get(_sr_lo, 3) : na
    float _l4 = array.size(_sr_lo) > 4 ? array.get(_sr_lo, 4) : na
    float _s0 = array.size(_sr_st) > 0 ? array.get(_sr_st, 0) : na
    float _s1 = array.size(_sr_st) > 1 ? array.get(_sr_st, 1) : na
    float _s2 = array.size(_sr_st) > 2 ? array.get(_sr_st, 2) : na
    float _s3 = array.size(_sr_st) > 3 ? array.get(_sr_st, 3) : na
    float _s4 = array.size(_sr_st) > 4 ? array.get(_sr_st, 4) : na
    [_m0, _m1, _m2, _m3, _m4, _h0, _h1, _h2, _h3, _h4, _l0, _l1, _l2, _l3, _l4, _s0, _s1, _s2, _s3, _s4]

// ──────────────────────────────────────────────────────────────
// REQUEST S/R
// ──────────────────────────────────────────────────────────────
[tf1_m0,tf1_m1,tf1_m2,tf1_m3,tf1_m4,tf1_h0,tf1_h1,tf1_h2,tf1_h3,tf1_h4,tf1_l0,tf1_l1,tf1_l2,tf1_l3,tf1_l4,tf1_s0,tf1_s1,tf1_s2,tf1_s3,tf1_s4] = request.security(syminfo.tickerid, tf1, calcSR())
[tf2_m0,tf2_m1,tf2_m2,tf2_m3,tf2_m4,tf2_h0,tf2_h1,tf2_h2,tf2_h3,tf2_h4,tf2_l0,tf2_l1,tf2_l2,tf2_l3,tf2_l4,tf2_s0,tf2_s1,tf2_s2,tf2_s3,tf2_s4] = request.security(syminfo.tickerid, tf2, calcSR())

// ──────────────────────────────────────────────────────────────
// ZONE COLORS
// ──────────────────────────────────────────────────────────────
zFill(mid, resC, supC) => not na(mid) ? (mid >= close ? color.new(resC, zoneTransp) : color.new(supC, zoneTransp)) : na
zMid(mid, resC, supC)  => not na(mid) ? (mid >= close ? color.new(resC, 40) : color.new(supC, 40)) : na

// ──────────────────────────────────────────────────────────────
// TF1 — 5 zones (15 plots + 5 fills = 20)
// ──────────────────────────────────────────────────────────────
float t1h0 = useTF1 ? tf1_h0 : na, float t1l0 = useTF1 ? tf1_l0 : na, float t1m0 = useTF1 ? tf1_m0 : na
float t1h1 = useTF1 ? tf1_h1 : na, float t1l1 = useTF1 ? tf1_l1 : na, float t1m1 = useTF1 ? tf1_m1 : na
float t1h2 = useTF1 ? tf1_h2 : na, float t1l2 = useTF1 ? tf1_l2 : na, float t1m2 = useTF1 ? tf1_m2 : na
float t1h3 = useTF1 ? tf1_h3 : na, float t1l3 = useTF1 ? tf1_l3 : na, float t1m3 = useTF1 ? tf1_m3 : na
float t1h4 = useTF1 ? tf1_h4 : na, float t1l4 = useTF1 ? tf1_l4 : na, float t1m4 = useTF1 ? tf1_m4 : na

p1h0 = plot(t1h0, 'T1Z0H', color=color.new(color.white, 100), display=display.none, editable=false)
p1l0 = plot(t1l0, 'T1Z0L', color=color.new(color.white, 100), display=display.none, editable=false)
plot(t1m0, 'TF1 Zone 0', color=zMid(t1m0, tf1ResColor, tf1SupColor), linewidth=1)
fill(p1h0, p1l0, color=zFill(t1m0, tf1ResColor, tf1SupColor))

p1h1 = plot(t1h1, 'T1Z1H', color=color.new(color.white, 100), display=display.none, editable=false)
p1l1 = plot(t1l1, 'T1Z1L', color=color.new(color.white, 100), display=display.none, editable=false)
plot(t1m1, 'TF1 Zone 1', color=zMid(t1m1, tf1ResColor, tf1SupColor), linewidth=1)
fill(p1h1, p1l1, color=zFill(t1m1, tf1ResColor, tf1SupColor))

p1h2 = plot(t1h2, 'T1Z2H', color=color.new(color.white, 100), display=display.none, editable=false)
p1l2 = plot(t1l2, 'T1Z2L', color=color.new(color.white, 100), display=display.none, editable=false)
plot(t1m2, 'TF1 Zone 2', color=zMid(t1m2, tf1ResColor, tf1SupColor), linewidth=1)
fill(p1h2, p1l2, color=zFill(t1m2, tf1ResColor, tf1SupColor))

p1h3 = plot(t1h3, 'T1Z3H', color=color.new(color.white, 100), display=display.none, editable=false)
p1l3 = plot(t1l3, 'T1Z3L', color=color.new(color.white, 100), display=display.none, editable=false)
plot(t1m3, 'TF1 Zone 3', color=zMid(t1m3, tf1ResColor, tf1SupColor), linewidth=1)
fill(p1h3, p1l3, color=zFill(t1m3, tf1ResColor, tf1SupColor))

p1h4 = plot(t1h4, 'T1Z4H', color=color.new(color.white, 100), display=display.none, editable=false)
p1l4 = plot(t1l4, 'T1Z4L', color=color.new(color.white, 100), display=display.none, editable=false)
plot(t1m4, 'TF1 Zone 4', color=zMid(t1m4, tf1ResColor, tf1SupColor), linewidth=1)
fill(p1h4, p1l4, color=zFill(t1m4, tf1ResColor, tf1SupColor))

// ──────────────────────────────────────────────────────────────
// TF2 — 5 zones (15 plots + 5 fills = 20)
// Total: 30 plots + 10 fills = 40 (under 64 limit)
// ──────────────────────────────────────────────────────────────
float t2h0 = useTF2 ? tf2_h0 : na, float t2l0 = useTF2 ? tf2_l0 : na, float t2m0 = useTF2 ? tf2_m0 : na
float t2h1 = useTF2 ? tf2_h1 : na, float t2l1 = useTF2 ? tf2_l1 : na, float t2m1 = useTF2 ? tf2_m1 : na
float t2h2 = useTF2 ? tf2_h2 : na, float t2l2 = useTF2 ? tf2_l2 : na, float t2m2 = useTF2 ? tf2_m2 : na
float t2h3 = useTF2 ? tf2_h3 : na, float t2l3 = useTF2 ? tf2_l3 : na, float t2m3 = useTF2 ? tf2_m3 : na
float t2h4 = useTF2 ? tf2_h4 : na, float t2l4 = useTF2 ? tf2_l4 : na, float t2m4 = useTF2 ? tf2_m4 : na

p2h0 = plot(t2h0, 'T2Z0H', color=color.new(color.white, 100), display=display.none, editable=false)
p2l0 = plot(t2l0, 'T2Z0L', color=color.new(color.white, 100), display=display.none, editable=false)
plot(t2m0, 'TF2 Zone 0', color=zMid(t2m0, tf2ResColor, tf2SupColor), linewidth=1)
fill(p2h0, p2l0, color=zFill(t2m0, tf2ResColor, tf2SupColor))

p2h1 = plot(t2h1, 'T2Z1H', color=color.new(color.white, 100), display=display.none, editable=false)
p2l1 = plot(t2l1, 'T2Z1L', color=color.new(color.white, 100), display=display.none, editable=false)
plot(t2m1, 'TF2 Zone 1', color=zMid(t2m1, tf2ResColor, tf2SupColor), linewidth=1)
fill(p2h1, p2l1, color=zFill(t2m1, tf2ResColor, tf2SupColor))

p2h2 = plot(t2h2, 'T2Z2H', color=color.new(color.white, 100), display=display.none, editable=false)
p2l2 = plot(t2l2, 'T2Z2L', color=color.new(color.white, 100), display=display.none, editable=false)
plot(t2m2, 'TF2 Zone 2', color=zMid(t2m2, tf2ResColor, tf2SupColor), linewidth=1)
fill(p2h2, p2l2, color=zFill(t2m2, tf2ResColor, tf2SupColor))

p2h3 = plot(t2h3, 'T2Z3H', color=color.new(color.white, 100), display=display.none, editable=false)
p2l3 = plot(t2l3, 'T2Z3L', color=color.new(color.white, 100), display=display.none, editable=false)
plot(t2m3, 'TF2 Zone 3', color=zMid(t2m3, tf2ResColor, tf2SupColor), linewidth=1)
fill(p2h3, p2l3, color=zFill(t2m3, tf2ResColor, tf2SupColor))

p2h4 = plot(t2h4, 'T2Z4H', color=color.new(color.white, 100), display=display.none, editable=false)
p2l4 = plot(t2l4, 'T2Z4L', color=color.new(color.white, 100), display=display.none, editable=false)
plot(t2m4, 'TF2 Zone 4', color=zMid(t2m4, tf2ResColor, tf2SupColor), linewidth=1)
fill(p2h4, p2l4, color=zFill(t2m4, tf2ResColor, tf2SupColor))

// ──────────────────────────────────────────────────────────────
// LABELS (barstate.islast only — labels don't need to scale)
// ──────────────────────────────────────────────────────────────
tf1_mids = array.from(tf1_m0, tf1_m1, tf1_m2, tf1_m3, tf1_m4)
tf1_strs = array.from(tf1_s0, tf1_s1, tf1_s2, tf1_s3, tf1_s4)
tf2_mids = array.from(tf2_m0, tf2_m1, tf2_m2, tf2_m3, tf2_m4)
tf2_strs = array.from(tf2_s0, tf2_s1, tf2_s2, tf2_s3, tf2_s4)

var tf1_labels = array.new_label(5, na)
var tf2_labels = array.new_label(5, na)

drawLabels(bool use, array<float> mids, array<float> strs, array<label> labels, color resCol, color supCol, string tfStr) =>
    if use and barstate.islast and showLabels
        for i = 0 to 4
            label.delete(array.get(labels, i))
            float mid = array.get(mids, i)
            float str2 = array.get(strs, i)
            if not na(mid)
                bool isRes    = mid >= close
                color baseCol = isRes ? resCol : supCol
                float rate    = 100 * (mid - close) / close
                string strTxt = showStrength ? ' ×' + str.tostring(math.round(str2)) : ''
                string txt    = tfLabel(tfStr) + ' ' + str.tostring(mid) + ' ' + str.tostring(rate, '#.##') + '%' + strTxt
                array.set(labels, i, label.new(bar_index + labelloc, mid, txt, color=color.new(baseCol, 20), textcolor=color.white, style=isRes ? label.style_label_down : label.style_label_up, size=size.small))

drawLabels(useTF1, tf1_mids, tf1_strs, tf1_labels, tf1ResColor, tf1SupColor, tf1)
drawLabels(useTF2, tf2_mids, tf2_strs, tf2_labels, tf2ResColor, tf2SupColor, tf2)

// ──────────────────────────────────────────────────────────────
// SIGNAL DETECTION
// ──────────────────────────────────────────────────────────────
var allMids = array.new_float(0)
array.clear(allMids)
if useTF1
    for i = 0 to 4
        if not na(array.get(tf1_mids, i))
            array.push(allMids, array.get(tf1_mids, i))
if useTF2
    for i = 0 to 4
        if not na(array.get(tf2_mids, i))
            array.push(allMids, array.get(tf2_mids, i))

crossed_over  = false
crossed_under = false
near_level    = false
for x = 0 to array.size(allMids) > 0 ? array.size(allMids) - 1 : na
    float mid = array.get(allMids, x)
    if close[1] <= mid and close > mid
        crossed_over := true
    if close[1] >= mid and close < mid
        crossed_under := true
    if alertProximity
        float dist = math.abs(close - mid) / mid * 100
        if dist <= proximityPct and dist > 0
            near_level := true

// ──────────────────────────────────────────────────────────────
// ALERTS
// ──────────────────────────────────────────────────────────────
alertcondition(crossed_over, title='Resistance Broken', message='🔴 Resistance Broken on {{ticker}} at {{close}} ({{interval}})')
alertcondition(crossed_under, title='Support Broken', message='🟢 Support Broken on {{ticker}} at {{close}} ({{interval}})')
alertcondition(crossed_over or crossed_under, title='S/R Level Broken', message='⚡️ S/R Level Broken on {{ticker}} at {{close}} ({{interval}})')
alertcondition(near_level, title='Approaching S/R', message='⚠️ {{ticker}} approaching S/R at {{close}} ({{interval}})')

// ──────────────────────────────────────────────────────────────
// DASHBOARD
// ──────────────────────────────────────────────────────────────
var table dash = table.new(position.top_right, 2, 3, bgcolor=color.new(#0a0a0c, 10), border_width=1, border_color=color.new(color.white, 90))
if barstate.islast
    int aC = 0, int sC = 0, int rC = 0
    for i = 0 to array.size(allMids) - 1
        aC += 1
        if array.get(allMids, i) < close
            sC += 1
        else
            rC += 1
    table.cell(dash, 0, 0, 'PW ZONES', text_color=#00e5a0, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 0, str.tostring(aC), text_color=color.white, text_size=size.small)
    table.cell(dash, 0, 1, 'S', text_color=color.new(#00e5a0, 30), text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 1, str.tostring(sC), text_color=color.new(#00e5a0, 30), text_size=size.tiny)
    table.cell(dash, 0, 2, 'R', text_color=color.new(#ff4976, 30), text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 2, str.tostring(rC), text_color=color.new(#ff4976, 30), text_size=size.tiny)
