//@version=6
indicator("PulseWave Zones", "PW Zones", overlay=true, max_labels_count=500)

// ──────────────────────────────────────────────────────────────────────────────
// INPUTS
// ──────────────────────────────────────────────────────────────────────────────

g_detect    = "Zone Detection"
pivotLeft   = input.int(10,    "Pivot Lookback",        group=g_detect, minval=2, maxval=50)
pivotRight  = input.int(3,     "Pivot Confirm",         group=g_detect, minval=1, maxval=10)
mergeDist   = input.float(0.3, "Merge Distance %",      group=g_detect, minval=0.05, maxval=2.0, step=0.05)
useATRwidth = input.bool(true, "ATR-Based Zone Width",   group=g_detect)
fixedWidth  = input.float(0.15,"Fixed Zone Width %",     group=g_detect, minval=0.05, maxval=1.0, step=0.05)
atrLen      = input.int(14,    "ATR Length",             group=g_detect, minval=5, maxval=50)
atrMult     = input.float(0.4, "ATR Width Multiplier",   group=g_detect, minval=0.1, maxval=2.0, step=0.1)

g_rules     = "Zone Rules"
maxTouches  = input.int(5,     "Max Touches (Depletion)", group=g_rules, minval=2, maxval=10)
hideOld     = input.int(300,   "Hide Zones Older Than (bars)", group=g_rules, minval=50, maxval=2000)

g_mtf       = "Multi-Timeframe"
useMTF      = input.bool(true, "Enable HTF Zones",       group=g_mtf)
htfTF       = input.timeframe("60", "Higher Timeframe",   group=g_mtf)
htfPivotL   = input.int(10,    "HTF Pivot Lookback",     group=g_mtf, minval=2, maxval=50)
htfPivotR   = input.int(3,     "HTF Pivot Confirm",      group=g_mtf, minval=1, maxval=10)

g_style     = "Style"
supFill     = input.color(color.new(#00e5a0, 85), "Support Zone",     group=g_style)
resFill     = input.color(color.new(#ff4976, 85), "Resistance Zone",   group=g_style)
htfSupFill  = input.color(color.new(#00e5a0, 75), "HTF Support",      group=g_style)
htfResFill  = input.color(color.new(#ff4976, 75), "HTF Resistance",    group=g_style)
flipFill    = input.color(color.new(#ffa500, 80), "Flipped Zone",      group=g_style)
showLabels  = input.bool(true, "Show Zone Labels",    group=g_style)

// ──────────────────────────────────────────────────────────────────────────────
// ZONE DATA — 12 fixed slots
// ──────────────────────────────────────────────────────────────────────────────

var float[] zTop       = array.new_float(12, na)
var float[] zBot       = array.new_float(12, na)
var float[] zMid       = array.new_float(12, na)
var int[]   zTouches   = array.new_int(12, 0)
var bool[]  zIsBull    = array.new_bool(12, true)
var bool[]  zAlive     = array.new_bool(12, false)
var bool[]  zFlipped   = array.new_bool(12, false)
var int[]   zBirth     = array.new_int(12, 0)
var bool[]  zIsHTF     = array.new_bool(12, false)

atrVal = ta.atr(atrLen)

getHalfWidth(price) =>
    useATRwidth ? atrVal * atrMult : price * fixedWidth / 100.0

findEmptySlot() =>
    result = -1
    for i = 0 to 11
        if not array.get(zAlive, i)
            result := i
            break
    result

findWeakestSlot() =>
    worstIdx = 0
    worstScore = -1.0
    for i = 0 to 11
        if array.get(zAlive, i)
            score = array.get(zTouches, i) * 1000.0 + (bar_index - array.get(zBirth, i))
            if score > worstScore
                worstScore := score
                worstIdx   := i
    worstIdx

addZone(price, isBull, isHTF) =>
    hw    = getHalfWidth(price)
    mDist = price * mergeDist / 100.0
    merged = false
    for i = 0 to 11
        if array.get(zAlive, i) and array.get(zIsBull, i) == isBull and array.get(zIsHTF, i) == isHTF
            if math.abs(array.get(zMid, i) - price) < mDist
                oldMid = array.get(zMid, i)
                oldT   = array.get(zTouches, i)
                newMid = (oldMid * (oldT + 1) + price) / (oldT + 2)
                array.set(zMid, i, newMid)
                array.set(zTop, i, newMid + getHalfWidth(newMid))
                array.set(zBot, i, newMid - getHalfWidth(newMid))
                merged := true
                break
    if not merged
        slot = findEmptySlot()
        if slot == -1
            slot := findWeakestSlot()
            array.set(zAlive, slot, false)
        if slot >= 0
            array.set(zTop, slot, price + hw)
            array.set(zBot, slot, price - hw)
            array.set(zMid, slot, price)
            array.set(zTouches, slot, 0)
            array.set(zIsBull, slot, isBull)
            array.set(zAlive, slot, true)
            array.set(zFlipped, slot, false)
            array.set(zBirth, slot, bar_index)
            array.set(zIsHTF, slot, isHTF)

// ──────────────────────────────────────────────────────────────────────────────
// PIVOTS
// ──────────────────────────────────────────────────────────────────────────────

pivHi = ta.pivothigh(high, pivotLeft, pivotRight)
pivLo = ta.pivotlow(low, pivotLeft, pivotRight)
if not na(pivHi)
    addZone(pivHi, false, false)
if not na(pivLo)
    addZone(pivLo, true, false)

[htfH, htfL, htfC] = request.security(syminfo.tickerid, htfTF, [high, low, close])
htfPivHi = ta.pivothigh(htfH, htfPivotL, htfPivotR)
htfPivLo = ta.pivotlow(htfL, htfPivotL, htfPivotR)
if useMTF
    if not na(htfPivHi)
        addZone(htfPivHi, false, true)
    if not na(htfPivLo)
        addZone(htfPivLo, true, true)

// ──────────────────────────────────────────────────────────────────────────────
// TOUCH / FLIP / DEPLETION
// ──────────────────────────────────────────────────────────────────────────────

for i = 0 to 11
    if not array.get(zAlive, i)
        continue
    zt = array.get(zTop, i)
    zb = array.get(zBot, i)
    touches = array.get(zTouches, i)
    isBull  = array.get(zIsBull, i)
    flipped = array.get(zFlipped, i)

    inZone = low <= zt and high >= zb
    prevIn = low[1] <= zt and high[1] >= zb
    if inZone and not prevIn
        array.set(zTouches, i, touches + 1)
        touches := touches + 1

    if touches >= maxTouches
        array.set(zAlive, i, false)
        continue

    if isBull and close < zb and close[1] < zb
        if not flipped
            array.set(zFlipped, i, true)
            array.set(zIsBull, i, false)
            array.set(zTouches, i, math.max(0, touches - 2))
        else
            array.set(zAlive, i, false)
    if not isBull and close > zt and close[1] > zt
        if not flipped
            array.set(zFlipped, i, true)
            array.set(zIsBull, i, true)
            array.set(zTouches, i, math.max(0, touches - 2))
        else
            array.set(zAlive, i, false)

    if bar_index - array.get(zBirth, i) > hideOld
        array.set(zAlive, i, false)

// ──────────────────────────────────────────────────────────────────────────────
// OUTPUT — plot() + fill() per slot
// Each slot emits a top and bottom value (na when inactive)
// ──────────────────────────────────────────────────────────────────────────────

slotTop(i) => array.get(zAlive, i) ? array.get(zTop, i) : na
slotBot(i) => array.get(zAlive, i) ? array.get(zBot, i) : na

slotColor(i) =>
    if not array.get(zAlive, i)
        color(na)
    else if array.get(zFlipped, i)
        flipFill
    else if array.get(zIsHTF, i)
        array.get(zIsBull, i) ? htfSupFill : htfResFill
    else
        array.get(zIsBull, i) ? supFill : resFill

// Border line color (more visible)
slotBorder(i) =>
    if not array.get(zAlive, i)
        color(na)
    else
        a = 50 + array.get(zTouches, i) * 8
        if array.get(zFlipped, i)
            color.new(#ffa500, a)
        else
            array.get(zIsBull, i) ? color.new(#00e5a0, a) : color.new(#ff4976, a)

// 12 plot pairs
t0=plot(slotTop(0),color=slotBorder(0),linewidth=1,editable=false,display=display.all)
b0=plot(slotBot(0),color=slotBorder(0),linewidth=1,editable=false,display=display.all)
t1=plot(slotTop(1),color=slotBorder(1),linewidth=1,editable=false,display=display.all)
b1=plot(slotBot(1),color=slotBorder(1),linewidth=1,editable=false,display=display.all)
t2=plot(slotTop(2),color=slotBorder(2),linewidth=1,editable=false,display=display.all)
b2=plot(slotBot(2),color=slotBorder(2),linewidth=1,editable=false,display=display.all)
t3=plot(slotTop(3),color=slotBorder(3),linewidth=1,editable=false,display=display.all)
b3=plot(slotBot(3),color=slotBorder(3),linewidth=1,editable=false,display=display.all)
t4=plot(slotTop(4),color=slotBorder(4),linewidth=1,editable=false,display=display.all)
b4=plot(slotBot(4),color=slotBorder(4),linewidth=1,editable=false,display=display.all)
t5=plot(slotTop(5),color=slotBorder(5),linewidth=1,editable=false,display=display.all)
b5=plot(slotBot(5),color=slotBorder(5),linewidth=1,editable=false,display=display.all)
t6=plot(slotTop(6),color=slotBorder(6),linewidth=1,editable=false,display=display.all)
b6=plot(slotBot(6),color=slotBorder(6),linewidth=1,editable=false,display=display.all)
t7=plot(slotTop(7),color=slotBorder(7),linewidth=1,editable=false,display=display.all)
b7=plot(slotBot(7),color=slotBorder(7),linewidth=1,editable=false,display=display.all)
t8=plot(slotTop(8),color=slotBorder(8),linewidth=1,editable=false,display=display.all)
b8=plot(slotBot(8),color=slotBorder(8),linewidth=1,editable=false,display=display.all)
t9=plot(slotTop(9),color=slotBorder(9),linewidth=1,editable=false,display=display.all)
b9=plot(slotBot(9),color=slotBorder(9),linewidth=1,editable=false,display=display.all)
t10=plot(slotTop(10),color=slotBorder(10),linewidth=1,editable=false,display=display.all)
b10=plot(slotBot(10),color=slotBorder(10),linewidth=1,editable=false,display=display.all)
t11=plot(slotTop(11),color=slotBorder(11),linewidth=1,editable=false,display=display.all)
b11=plot(slotBot(11),color=slotBorder(11),linewidth=1,editable=false,display=display.all)

fill(t0,b0,color=slotColor(0))
fill(t1,b1,color=slotColor(1))
fill(t2,b2,color=slotColor(2))
fill(t3,b3,color=slotColor(3))
fill(t4,b4,color=slotColor(4))
fill(t5,b5,color=slotColor(5))
fill(t6,b6,color=slotColor(6))
fill(t7,b7,color=slotColor(7))
fill(t8,b8,color=slotColor(8))
fill(t9,b9,color=slotColor(9))
fill(t10,b10,color=slotColor(10))
fill(t11,b11,color=slotColor(11))

// ──────────────────────────────────────────────────────────────────────────────
// LABELS
// ──────────────────────────────────────────────────────────────────────────────

if barstate.islast and showLabels
    allLb = label.all
    if array.size(allLb) > 0
        for i = 0 to array.size(allLb) - 1
            label.delete(array.get(allLb, i))
    for i = 0 to 11
        if not array.get(zAlive, i)
            continue
        isBull  = array.get(zIsBull, i)
        touches = array.get(zTouches, i)
        isHTF   = array.get(zIsHTF, i)
        flipped = array.get(zFlipped, i)
        txt = (isBull ? "S " : "R ") + str.tostring(touches) + "/" + str.tostring(maxTouches) + (isHTF ? " HTF" : "") + (flipped ? " ⟲" : "")
        lCol = flipped ? color.new(#ffa500, 20) : isBull ? color.new(#00e5a0, 20) : color.new(#ff4976, 20)
        yP = isBull ? array.get(zBot, i) : array.get(zTop, i)
        label.new(bar_index + 5, yP, txt, style=isBull ? label.style_label_up : label.style_label_down, color=color.new(color.black, 85), textcolor=lCol, size=size.tiny)

// ──────────────────────────────────────────────────────────────────────────────
// ALERTS + DASHBOARD
// ──────────────────────────────────────────────────────────────────────────────

nearSup = false
nearRes = false
for i = 0 to 11
    if array.get(zAlive, i)
        zt = array.get(zTop, i)
        zb = array.get(zBot, i)
        if array.get(zIsBull, i) and low < zt + atrVal * 1.5 and low > zb
            nearSup := true
        if not array.get(zIsBull, i) and high > zb - atrVal * 1.5 and high < zt
            nearRes := true

alertcondition(nearSup, "Near Support", "Approaching support")
alertcondition(nearRes, "Near Resistance", "Approaching resistance")

var table dash = table.new(position.top_right, 2, 3, bgcolor=color.new(#0a0a0c, 10), border_width=1, border_color=color.new(color.white, 90))
if barstate.islast
    aC = 0
    sC = 0
    rC = 0
    for i = 0 to 11
        if array.get(zAlive, i)
            aC += 1
            if array.get(zIsBull, i)
                sC += 1
            else
                rC += 1
    table.cell(dash, 0, 0, "PW ZONES", text_color=#00e5a0, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 0, str.tostring(aC), text_color=color.white, text_size=size.small)
    table.cell(dash, 0, 1, "S", text_color=color.new(#00e5a0, 30), text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 1, str.tostring(sC), text_color=color.new(#00e5a0, 30), text_size=size.tiny)
    table.cell(dash, 0, 2, "R", text_color=color.new(#ff4976, 30), text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 2, str.tostring(rC), text_color=color.new(#ff4976, 30), text_size=size.tiny)
