//@version=6
indicator("PulseWave Zones", "PW Zones", overlay=true, max_labels_count=500)

// ──────────────────────────────────────────────────────────────────────────────
// INPUTS
// ──────────────────────────────────────────────────────────────────────────────

g_detect    = "Zone Detection"
pivotLeft   = input.int(10,    "Pivot Lookback",        group=g_detect, minval=2, maxval=50)
pivotRight  = input.int(3,     "Pivot Confirm",         group=g_detect, minval=1, maxval=10)
mergeDist   = input.float(0.3, "Merge Distance %",      group=g_detect, minval=0.05, maxval=2.0, step=0.05)
useATRwidth = input.bool(true, "ATR-Based Zone Width",   group=g_detect)
fixedWidth  = input.float(0.15,"Fixed Zone Width %",     group=g_detect, minval=0.05, maxval=1.0, step=0.05)
atrLen      = input.int(14,    "ATR Length",             group=g_detect, minval=5, maxval=50)
atrMult     = input.float(0.4, "ATR Width Multiplier",   group=g_detect, minval=0.1, maxval=2.0, step=0.1)

g_rules     = "Zone Rules"
maxTouches  = input.int(5,     "Max Touches (Depletion)", group=g_rules, minval=2, maxval=10)
hideOld     = input.int(300,   "Hide Zones Older Than (bars)", group=g_rules, minval=50, maxval=2000)

g_mtf       = "Multi-Timeframe"
useMTF      = input.bool(true, "Enable HTF Zones",       group=g_mtf)
htfTF       = input.timeframe("60", "Higher Timeframe",   group=g_mtf)
htfPivotL   = input.int(10,    "HTF Pivot Lookback",     group=g_mtf, minval=2, maxval=50)
htfPivotR   = input.int(3,     "HTF Pivot Confirm",      group=g_mtf, minval=1, maxval=10)

g_style     = "Style"
supColorIn  = input.color(color.new(#00e5a0, 75), "Support Fill",    group=g_style)
resColorIn  = input.color(color.new(#ff4976, 75), "Resistance Fill",  group=g_style)
htfAlpha    = input.int(60, "HTF Fill Transparency", group=g_style, minval=0, maxval=95)
freshColorIn = input.color(color.new(#ffd700, 70), "Fresh Zone Fill",  group=g_style)
showLabels  = input.bool(true, "Show Zone Labels",       group=g_style)

// ──────────────────────────────────────────────────────────────────────────────
// CONSTANTS — max 12 zone slots (12 top + 12 bot plot lines = 24 plots)
// ──────────────────────────────────────────────────────────────────────────────

MAX_ZONES = 12

// ──────────────────────────────────────────────────────────────────────────────
// ZONE DATA (flat parallel arrays)
// ──────────────────────────────────────────────────────────────────────────────

var float[] zTop       = array.new_float(MAX_ZONES, na)
var float[] zBot       = array.new_float(MAX_ZONES, na)
var float[] zMid       = array.new_float(MAX_ZONES, na)
var int[]   zTouches   = array.new_int(MAX_ZONES, 0)
var bool[]  zIsBull    = array.new_bool(MAX_ZONES, true)
var bool[]  zAlive     = array.new_bool(MAX_ZONES, false)
var bool[]  zFlipped   = array.new_bool(MAX_ZONES, false)
var int[]   zBirth     = array.new_int(MAX_ZONES, 0)
var int[]   zLastTouch = array.new_int(MAX_ZONES, 0)
var bool[]  zIsHTF     = array.new_bool(MAX_ZONES, false)

// ──────────────────────────────────────────────────────────────────────────────
// HELPERS
// ──────────────────────────────────────────────────────────────────────────────

atrVal = ta.atr(atrLen)

getHalfWidth(price) =>
    useATRwidth ? atrVal * atrMult : price * fixedWidth / 100.0

findEmptySlot() =>
    result = -1
    for i = 0 to MAX_ZONES - 1
        if not array.get(zAlive, i)
            result := i
            break
    result

findWeakestSlot() =>
    // Find alive zone with most touches (weakest) and oldest
    worstIdx = -1
    worstScore = -1.0
    for i = 0 to MAX_ZONES - 1
        if array.get(zAlive, i)
            age = bar_index - array.get(zBirth, i)
            score = array.get(zTouches, i) * 1000.0 + age
            if score > worstScore
                worstScore := score
                worstIdx   := i
    worstIdx

addZone(price, isBull, isHTF) =>
    hw   = getHalfWidth(price)
    _top = price + hw
    _bot = price - hw
    mDist = price * mergeDist / 100.0

    // Try merge
    merged = false
    for i = 0 to MAX_ZONES - 1
        if array.get(zAlive, i) and array.get(zIsBull, i) == isBull and array.get(zIsHTF, i) == isHTF
            if math.abs(array.get(zMid, i) - price) < mDist
                oldMid = array.get(zMid, i)
                oldT   = array.get(zTouches, i)
                newMid = (oldMid * (oldT + 1) + price) / (oldT + 2)
                array.set(zMid, i, newMid)
                array.set(zTop, i, newMid + getHalfWidth(newMid))
                array.set(zBot, i, newMid - getHalfWidth(newMid))
                merged := true
                break

    if not merged
        slot = findEmptySlot()
        if slot == -1
            slot := findWeakestSlot()
        if slot >= 0
            array.set(zTop, slot, _top)
            array.set(zBot, slot, _bot)
            array.set(zMid, slot, price)
            array.set(zTouches, slot, 0)
            array.set(zIsBull, slot, isBull)
            array.set(zAlive, slot, true)
            array.set(zFlipped, slot, false)
            array.set(zBirth, slot, bar_index)
            array.set(zLastTouch, slot, bar_index)
            array.set(zIsHTF, slot, isHTF)

// ──────────────────────────────────────────────────────────────────────────────
// PIVOT DETECTION
// ──────────────────────────────────────────────────────────────────────────────

pivHi = ta.pivothigh(high, pivotLeft, pivotRight)
pivLo = ta.pivotlow(low, pivotLeft, pivotRight)

if not na(pivHi)
    addZone(pivHi, false, false)
if not na(pivLo)
    addZone(pivLo, true, false)

// HTF
[htfH, htfL, htfC] = request.security(syminfo.tickerid, htfTF, [high, low, close])
htfPivHi = ta.pivothigh(htfH, htfPivotL, htfPivotR)
htfPivLo = ta.pivotlow(htfL, htfPivotL, htfPivotR)

if useMTF
    if not na(htfPivHi)
        addZone(htfPivHi, false, true)
    if not na(htfPivLo)
        addZone(htfPivLo, true, true)

// ──────────────────────────────────────────────────────────────────────────────
// TOUCH COUNTING, S/R FLIP, DEPLETION
// ──────────────────────────────────────────────────────────────────────────────

for i = 0 to MAX_ZONES - 1
    if not array.get(zAlive, i)
        continue

    zt = array.get(zTop, i)
    zb = array.get(zBot, i)
    isBull = array.get(zIsBull, i)
    touches = array.get(zTouches, i)

    inZone = low <= zt and high >= zb
    prevIn = low[1] <= zt and high[1] >= zb
    if inZone and not prevIn
        array.set(zTouches, i, touches + 1)
        array.set(zLastTouch, i, bar_index)
        touches := touches + 1

    if touches >= maxTouches
        array.set(zAlive, i, false)
        continue

    flipped = array.get(zFlipped, i)
    if isBull and close < zb and close[1] < zb
        if not flipped
            array.set(zFlipped, i, true)
            array.set(zIsBull, i, false)
            array.set(zTouches, i, math.max(0, touches - 2))
        else
            array.set(zAlive, i, false)

    if not isBull and close > zt and close[1] > zt
        if not flipped
            array.set(zFlipped, i, true)
            array.set(zIsBull, i, true)
            array.set(zTouches, i, math.max(0, touches - 2))
        else
            array.set(zAlive, i, false)

    if bar_index - array.get(zBirth, i) > hideOld
        array.set(zAlive, i, false)

// ──────────────────────────────────────────────────────────────────────────────
// OUTPUT VALUES — each slot gets a top/bot value (na when inactive)
// ──────────────────────────────────────────────────────────────────────────────

getTop(idx) => array.get(zAlive, idx) ? array.get(zTop, idx) : na
getBot(idx) => array.get(zAlive, idx) ? array.get(zBot, idx) : na

getColor(idx) =>
    if not array.get(zAlive, idx)
        color(na)
    else
        isBull  = array.get(zIsBull, idx)
        isHTF   = array.get(zIsHTF, idx)
        isFresh = array.get(zTouches, idx) == 0
        flipped = array.get(zFlipped, idx)
        if flipped
            color.new(#ffa500, 70)
        else if isFresh
            freshColorIn
        else if isHTF
            isBull ? color.new(#00e5a0, htfAlpha) : color.new(#ff4976, htfAlpha)
        else
            isBull ? supColorIn : resColorIn

// ──────────────────────────────────────────────────────────────────────────────
// PLOTS — 12 zone slots using plot() + fill()
// ──────────────────────────────────────────────────────────────────────────────

t0  = plot(getTop(0),  display=display.none, editable=false)
b0  = plot(getBot(0),  display=display.none, editable=false)
t1  = plot(getTop(1),  display=display.none, editable=false)
b1  = plot(getBot(1),  display=display.none, editable=false)
t2  = plot(getTop(2),  display=display.none, editable=false)
b2  = plot(getBot(2),  display=display.none, editable=false)
t3  = plot(getTop(3),  display=display.none, editable=false)
b3  = plot(getBot(3),  display=display.none, editable=false)
t4  = plot(getTop(4),  display=display.none, editable=false)
b4  = plot(getBot(4),  display=display.none, editable=false)
t5  = plot(getTop(5),  display=display.none, editable=false)
b5  = plot(getBot(5),  display=display.none, editable=false)
t6  = plot(getTop(6),  display=display.none, editable=false)
b6  = plot(getBot(6),  display=display.none, editable=false)
t7  = plot(getTop(7),  display=display.none, editable=false)
b7  = plot(getBot(7),  display=display.none, editable=false)
t8  = plot(getTop(8),  display=display.none, editable=false)
b8  = plot(getBot(8),  display=display.none, editable=false)
t9  = plot(getTop(9),  display=display.none, editable=false)
b9  = plot(getBot(9),  display=display.none, editable=false)
t10 = plot(getTop(10), display=display.none, editable=false)
b10 = plot(getBot(10), display=display.none, editable=false)
t11 = plot(getTop(11), display=display.none, editable=false)
b11 = plot(getBot(11), display=display.none, editable=false)

fill(t0,  b0,  getColor(0))
fill(t1,  b1,  getColor(1))
fill(t2,  b2,  getColor(2))
fill(t3,  b3,  getColor(3))
fill(t4,  b4,  getColor(4))
fill(t5,  b5,  getColor(5))
fill(t6,  b6,  getColor(6))
fill(t7,  b7,  getColor(7))
fill(t8,  b8,  getColor(8))
fill(t9,  b9,  getColor(9))
fill(t10, b10, getColor(10))
fill(t11, b11, getColor(11))

// ──────────────────────────────────────────────────────────────────────────────
// LABELS (on last bar only)
// ──────────────────────────────────────────────────────────────────────────────

if barstate.islast and showLabels
    aLb = label.all
    if array.size(aLb) > 0
        for i = 0 to array.size(aLb) - 1
            label.delete(array.get(aLb, i))

    for i = 0 to MAX_ZONES - 1
        if array.get(zAlive, i)
            isBull  = array.get(zIsBull, i)
            touches = array.get(zTouches, i)
            isHTF   = array.get(zIsHTF, i)
            flipped = array.get(zFlipped, i)

            typeTxt = isBull ? "S" : "R"
            touchTxt = str.tostring(touches) + "/" + str.tostring(maxTouches)
            htfTxt  = isHTF ? " HTF" : ""
            flipTxt = flipped ? " ⟲" : ""
            fullTxt = typeTxt + " " + touchTxt + htfTxt + flipTxt

            lblColor = flipped ? color.new(#ffa500, 20) : isBull ? color.new(#00e5a0, 20) : color.new(#ff4976, 20)
            yPos     = isBull ? array.get(zBot, i) : array.get(zTop, i)
            lblStyle = isBull ? label.style_label_up : label.style_label_down

            label.new(bar_index + 5, yPos, fullTxt,
                 style=lblStyle, color=color.new(color.black, 80),
                 textcolor=lblColor, size=size.tiny)

// ──────────────────────────────────────────────────────────────────────────────
// PROXIMITY ALERTS
// ──────────────────────────────────────────────────────────────────────────────

nearSup = false
nearRes = false
alertDist = atrVal * 1.5

for i = 0 to MAX_ZONES - 1
    if array.get(zAlive, i)
        zt = array.get(zTop, i)
        zb = array.get(zBot, i)
        if array.get(zIsBull, i) and low < zt + alertDist and low > zb
            nearSup := true
        if not array.get(zIsBull, i) and high > zb - alertDist and high < zt
            nearRes := true

alertcondition(nearSup, "Near Strong Support",    "Price approaching support zone")
alertcondition(nearRes, "Near Strong Resistance", "Price approaching resistance zone")
barcolor(nearSup ? color.new(#00e5a0, 70) : nearRes ? color.new(#ff4976, 70) : na)

// ──────────────────────────────────────────────────────────────────────────────
// DASHBOARD
// ──────────────────────────────────────────────────────────────────────────────

var table dash = table.new(position.top_right, 2, 5, bgcolor=color.new(#0a0a0c, 10), border_width=1, border_color=color.new(color.white, 90))

if barstate.islast
    aC = 0
    sC = 0
    rC = 0
    hC = 0
    fC = 0
    for i = 0 to MAX_ZONES - 1
        if array.get(zAlive, i)
            aC += 1
            if array.get(zIsBull, i)
                sC += 1
            else
                rC += 1
            if array.get(zIsHTF, i)
                hC += 1
            if array.get(zFlipped, i)
                fC += 1

    table.cell(dash, 0, 0, "PW ZONES", text_color=#00e5a0, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 0, str.tostring(aC), text_color=color.white, text_size=size.small)
    table.cell(dash, 0, 1, "Support",  text_color=color.new(#00e5a0, 30), text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 1, str.tostring(sC), text_color=color.new(#00e5a0, 30), text_size=size.tiny)
    table.cell(dash, 0, 2, "Resist",   text_color=color.new(#ff4976, 30), text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 2, str.tostring(rC), text_color=color.new(#ff4976, 30), text_size=size.tiny)
    table.cell(dash, 0, 3, "HTF",      text_color=color.gray, text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 3, str.tostring(hC), text_color=color.yellow, text_size=size.tiny)
    table.cell(dash, 0, 4, "Flipped",  text_color=color.gray, text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 4, str.tostring(fC), text_color=color.new(#ffa500, 30), text_size=size.tiny)
