//@version=6
indicator("PulseWave Zones", "PW Zones", overlay=true, max_boxes_count=500, max_labels_count=500)

// ──────────────────────────────────────────────────────────────────────────────
// INPUTS
// ──────────────────────────────────────────────────────────────────────────────

g_detect    = "Zone Detection"
pivotLeft   = input.int(10,    "Pivot Lookback",        group=g_detect, minval=2, maxval=50)
pivotRight  = input.int(3,     "Pivot Confirm",         group=g_detect, minval=1, maxval=10)
mergeDist   = input.float(0.3, "Merge Distance %",      group=g_detect, minval=0.05, maxval=2.0, step=0.05)
useATRwidth = input.bool(true, "ATR-Based Zone Width",   group=g_detect)
fixedWidth  = input.float(0.15,"Fixed Zone Width %",     group=g_detect, minval=0.05, maxval=1.0, step=0.05)
atrLen      = input.int(14,    "ATR Length",             group=g_detect, minval=5, maxval=50)
atrMult     = input.float(0.4, "ATR Width Multiplier",   group=g_detect, minval=0.1, maxval=2.0, step=0.1)

g_rules     = "Zone Rules"
maxTouches  = input.int(5,     "Max Touches (Depletion)", group=g_rules, minval=2, maxval=10)
maxZones    = input.int(12,    "Max Zones Shown",        group=g_rules, minval=4, maxval=30)
hideOld     = input.int(300,   "Hide Zones Older Than (bars)", group=g_rules, minval=50, maxval=2000)

g_mtf       = "Multi-Timeframe"
useMTF      = input.bool(true, "Enable HTF Zones",       group=g_mtf)
htfTF       = input.timeframe("60", "Higher Timeframe",   group=g_mtf)
htfPivotL   = input.int(10,    "HTF Pivot Lookback",     group=g_mtf, minval=2, maxval=50)
htfPivotR   = input.int(3,     "HTF Pivot Confirm",      group=g_mtf, minval=1, maxval=10)

g_style     = "Style"
bullColor   = input.color(#00e5a0, "Support Color",    group=g_style)
bearColor   = input.color(#ff4976, "Resistance Color",  group=g_style)
flipColor   = input.color(#ffa500, "Flipped Color",     group=g_style)
showLabels  = input.bool(true, "Show Zone Labels",    group=g_style)

// ──────────────────────────────────────────────────────────────────────────────
// ZONE UDT — same pattern as PulseWave Edge (which scales fine)
// ──────────────────────────────────────────────────────────────────────────────

type Zone
    float   top
    float   bot
    float   mid
    int     touches
    bool    isBull
    bool    alive
    bool    flipped
    int     birthTime
    bool    isHTF
    box     bx

var Zone[] zones = array.new<Zone>()

// ──────────────────────────────────────────────────────────────────────────────
// HELPERS
// ──────────────────────────────────────────────────────────────────────────────

atrVal = ta.atr(atrLen)

halfZone(price) =>
    useATRwidth ? atrVal * atrMult : price * fixedWidth / 100.0

makeBox(birthTime, _top, _bot, isBull, isHTF, flipped) =>
    col = flipped ? flipColor : isBull ? bullColor : bearColor
    alpha = isHTF ? 82 : 90
    bAlpha = isHTF ? 70 : 80
    bW = isHTF ? 2 : 1
    bS = flipped ? line.style_dashed : line.style_solid
    futureTime = time + timeframe.in_seconds() * 1000 * 10
    box.new(birthTime, _top, futureTime, _bot, xloc=xloc.bar_time, border_color=color.new(col, bAlpha), border_width=bW, border_style=bS, bgcolor=color.new(col, alpha))

// ──────────────────────────────────────────────────────────────────────────────
// ADD ZONES FROM PIVOTS
// ──────────────────────────────────────────────────────────────────────────────

pivHi = ta.pivothigh(high, pivotLeft, pivotRight)
pivLo = ta.pivotlow(low, pivotLeft, pivotRight)

if not na(pivHi)
    hw   = halfZone(pivHi)
    _top = pivHi + hw
    _bot = pivHi - hw
    merged = false
    for i = 0 to (array.size(zones) > 0 ? array.size(zones) - 1 : na)
        z = array.get(zones, i)
        if z.alive and not z.isBull and not z.isHTF
            if math.abs(z.mid - pivHi) / pivHi < mergeDist / 100.0
                z.mid := (z.mid + pivHi) / 2.0
                z.top := z.mid + halfZone(z.mid)
                z.bot := z.mid - halfZone(z.mid)
                if not na(z.bx)
                    box.set_top(z.bx, z.top)
                    box.set_bottom(z.bx, z.bot)
                merged := true
                break
    if not merged
        newZone = Zone.new(_top, _bot, pivHi, 0, false, true, false, time[pivotRight], false, na)
        newZone.bx := makeBox(time[pivotRight], _top, _bot, false, false, false)
        array.push(zones, newZone)

if not na(pivLo)
    hw   = halfZone(pivLo)
    _top = pivLo + hw
    _bot = pivLo - hw
    merged = false
    for i = 0 to (array.size(zones) > 0 ? array.size(zones) - 1 : na)
        z = array.get(zones, i)
        if z.alive and z.isBull and not z.isHTF
            if math.abs(z.mid - pivLo) / pivLo < mergeDist / 100.0
                z.mid := (z.mid + pivLo) / 2.0
                z.top := z.mid + halfZone(z.mid)
                z.bot := z.mid - halfZone(z.mid)
                if not na(z.bx)
                    box.set_top(z.bx, z.top)
                    box.set_bottom(z.bx, z.bot)
                merged := true
                break
    if not merged
        newZone = Zone.new(_top, _bot, pivLo, 0, true, true, false, time[pivotRight], false, na)
        newZone.bx := makeBox(time[pivotRight], _top, _bot, true, false, false)
        array.push(zones, newZone)

// HTF pivots
[htfH, htfL, htfC] = request.security(syminfo.tickerid, htfTF, [high, low, close])
htfPivHi = ta.pivothigh(htfH, htfPivotL, htfPivotR)
htfPivLo = ta.pivotlow(htfL, htfPivotL, htfPivotR)

if useMTF and not na(htfPivHi)
    hw   = halfZone(htfPivHi)
    _top = htfPivHi + hw
    _bot = htfPivHi - hw
    merged = false
    for i = 0 to (array.size(zones) > 0 ? array.size(zones) - 1 : na)
        z = array.get(zones, i)
        if z.alive and not z.isBull and z.isHTF
            if math.abs(z.mid - htfPivHi) / htfPivHi < mergeDist / 100.0
                z.mid := (z.mid + htfPivHi) / 2.0
                z.top := z.mid + halfZone(z.mid)
                z.bot := z.mid - halfZone(z.mid)
                if not na(z.bx)
                    box.set_top(z.bx, z.top)
                    box.set_bottom(z.bx, z.bot)
                merged := true
                break
    if not merged
        newZone = Zone.new(_top, _bot, htfPivHi, 0, false, true, false, time, true, na)
        newZone.bx := makeBox(time, _top, _bot, false, true, false)
        array.push(zones, newZone)

if useMTF and not na(htfPivLo)
    hw   = halfZone(htfPivLo)
    _top = htfPivLo + hw
    _bot = htfPivLo - hw
    merged = false
    for i = 0 to (array.size(zones) > 0 ? array.size(zones) - 1 : na)
        z = array.get(zones, i)
        if z.alive and z.isBull and z.isHTF
            if math.abs(z.mid - htfPivLo) / htfPivLo < mergeDist / 100.0
                z.mid := (z.mid + htfPivLo) / 2.0
                z.top := z.mid + halfZone(z.mid)
                z.bot := z.mid - halfZone(z.mid)
                if not na(z.bx)
                    box.set_top(z.bx, z.top)
                    box.set_bottom(z.bx, z.bot)
                merged := true
                break
    if not merged
        newZone = Zone.new(_top, _bot, htfPivLo, 0, true, true, false, time, true, na)
        newZone.bx := makeBox(time, _top, _bot, true, true, false)
        array.push(zones, newZone)

// ──────────────────────────────────────────────────────────────────────────────
// UPDATE ZONES — touch counting, S/R flip, depletion, extend boxes
// (Same pattern as PulseWave Edge)
// ──────────────────────────────────────────────────────────────────────────────

for i = 0 to (array.size(zones) > 0 ? array.size(zones) - 1 : na)
    z = array.get(zones, i)
    if z.alive
        inZone = low <= z.top and high >= z.bot
        prevLow  = low[1]
        prevHigh = high[1]
        wasOut = not (prevLow <= z.top and prevHigh >= z.bot)

        if inZone and wasOut
            z.touches += 1

        // Depletion
        if z.touches >= maxTouches
            z.alive := false
            if not na(z.bx)
                box.set_right(z.bx, time)
                box.set_bgcolor(z.bx, color.new(color.gray, 95))
                box.set_border_color(z.bx, color.new(color.gray, 90))

        // S/R flip
        if z.alive and z.isBull and close < z.bot and close[1] < z.bot
            if not z.flipped
                z.flipped := true
                z.isBull  := false
                z.touches := math.max(0, z.touches - 2)
                if not na(z.bx)
                    box.set_border_color(z.bx, color.new(flipColor, 70))
                    box.set_bgcolor(z.bx, color.new(flipColor, 88))
                    box.set_border_style(z.bx, line.style_dashed)
            else
                z.alive := false
                if not na(z.bx)
                    box.delete(z.bx)

        if z.alive and not z.isBull and close > z.top and close[1] > z.top
            if not z.flipped
                z.flipped := true
                z.isBull  := true
                z.touches := math.max(0, z.touches - 2)
                if not na(z.bx)
                    box.set_border_color(z.bx, color.new(flipColor, 70))
                    box.set_bgcolor(z.bx, color.new(flipColor, 88))
                    box.set_border_style(z.bx, line.style_dashed)
            else
                z.alive := false
                if not na(z.bx)
                    box.delete(z.bx)

        // Too old
        if z.alive and (time - z.birthTime) > hideOld * timeframe.in_seconds() * 1000
            z.alive := false
            if not na(z.bx)
                box.delete(z.bx)

        // Extend alive zones + fade with touches
        if z.alive and not na(z.bx)
            box.set_right(z.bx, time + timeframe.in_seconds() * 1000 * 10)
            opac = 88 + z.touches * 2
            col = z.flipped ? flipColor : z.isBull ? bullColor : bearColor
            box.set_bgcolor(z.bx, color.new(col, math.min(opac, 96)))

// ──────────────────────────────────────────────────────────────────────────────
// PRUNE — keep only strongest zones if too many
// ──────────────────────────────────────────────────────────────────────────────

aliveCount = 0
for i = 0 to (array.size(zones) > 0 ? array.size(zones) - 1 : na)
    z = array.get(zones, i)
    if z.alive
        aliveCount += 1

if aliveCount > maxZones
    for _kill = 0 to aliveCount - maxZones - 1
        worstIdx = -1
        worstScore = -1.0
        for i = 0 to array.size(zones) - 1
            z = array.get(zones, i)
            if z.alive
                score = z.touches * 1000.0 + (time - z.birthTime) / 1000.0
                if score > worstScore
                    worstScore := score
                    worstIdx   := i
        if worstIdx >= 0
            zKill = array.get(zones, worstIdx)
            zKill.alive := false
            if not na(zKill.bx)
                box.delete(zKill.bx)

// ──────────────────────────────────────────────────────────────────────────────
// LABELS — on last bar only
// ──────────────────────────────────────────────────────────────────────────────

if barstate.islast and showLabels
    allLb = label.all
    if array.size(allLb) > 0
        for i = 0 to array.size(allLb) - 1
            label.delete(array.get(allLb, i))

    for i = 0 to (array.size(zones) > 0 ? array.size(zones) - 1 : na)
        z = array.get(zones, i)
        if z.alive
            txt = (z.isBull ? "S " : "R ") + str.tostring(z.touches) + "/" + str.tostring(maxTouches) + (z.isHTF ? " HTF" : "") + (z.flipped ? " ⟲" : "")
            col = z.flipped ? flipColor : z.isBull ? bullColor : bearColor
            yP  = z.isBull ? z.bot : z.top
            label.new(bar_index + 12, yP, txt, style=z.isBull ? label.style_label_up : label.style_label_down, color=color.new(color.black, 85), textcolor=color.new(col, 20), size=size.tiny)

// ──────────────────────────────────────────────────────────────────────────────
// ALERTS
// ──────────────────────────────────────────────────────────────────────────────

nearSup = false
nearRes = false
for i = 0 to (array.size(zones) > 0 ? array.size(zones) - 1 : na)
    z = array.get(zones, i)
    if z.alive
        if z.isBull and low < z.top + atrVal * 1.5 and low > z.bot
            nearSup := true
        if not z.isBull and high > z.bot - atrVal * 1.5 and high < z.top
            nearRes := true

alertcondition(nearSup, "Near Support", "Approaching support")
alertcondition(nearRes, "Near Resistance", "Approaching resistance")

// ──────────────────────────────────────────────────────────────────────────────
// DASHBOARD
// ──────────────────────────────────────────────────────────────────────────────

var table dash = table.new(position.top_right, 2, 3, bgcolor=color.new(#0a0a0c, 10), border_width=1, border_color=color.new(color.white, 90))
if barstate.islast
    aC = 0
    sC = 0
    rC = 0
    for i = 0 to (array.size(zones) > 0 ? array.size(zones) - 1 : na)
        z = array.get(zones, i)
        if z.alive
            aC += 1
            if z.isBull
                sC += 1
            else
                rC += 1
    table.cell(dash, 0, 0, "PW ZONES", text_color=#00e5a0, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 0, str.tostring(aC), text_color=color.white, text_size=size.small)
    table.cell(dash, 0, 1, "S", text_color=color.new(#00e5a0, 30), text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 1, str.tostring(sC), text_color=color.new(#00e5a0, 30), text_size=size.tiny)
    table.cell(dash, 0, 2, "R", text_color=color.new(#ff4976, 30), text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 2, str.tostring(rC), text_color=color.new(#ff4976, 30), text_size=size.tiny)
