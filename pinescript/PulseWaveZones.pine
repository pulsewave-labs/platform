//@version=6
indicator("PulseWave Zones", "PW Zones", overlay=true, max_lines_count=500, max_labels_count=500)

// ──────────────────────────────────────────────────────────────────────────────
// INPUTS
// ──────────────────────────────────────────────────────────────────────────────

g_detect    = "Zone Detection"
pivotLeft   = input.int(10,    "Pivot Lookback",        group=g_detect, minval=2, maxval=50)
pivotRight  = input.int(3,     "Pivot Confirm",         group=g_detect, minval=1, maxval=10)
mergeDist   = input.float(0.3, "Merge Distance %",      group=g_detect, minval=0.05, maxval=2.0, step=0.05)
useATRwidth = input.bool(true, "ATR-Based Zone Width",   group=g_detect)
fixedWidth  = input.float(0.15,"Fixed Zone Width %",     group=g_detect, minval=0.05, maxval=1.0, step=0.05)
atrLen      = input.int(14,    "ATR Length",             group=g_detect, minval=5, maxval=50)
atrMult     = input.float(0.4, "ATR Width Multiplier",   group=g_detect, minval=0.1, maxval=2.0, step=0.1)

g_rules     = "Zone Rules"
maxTouches  = input.int(5,     "Max Touches (Depletion)", group=g_rules, minval=2, maxval=10)
maxZones    = input.int(12,    "Max Zones Shown",        group=g_rules, minval=4, maxval=30)
hideOld     = input.int(300,   "Hide Zones Older Than (bars)", group=g_rules, minval=50, maxval=2000)

g_mtf       = "Multi-Timeframe"
useMTF      = input.bool(true, "Enable HTF Zones",       group=g_mtf)
htfTF       = input.timeframe("60", "Higher Timeframe",   group=g_mtf)
htfPivotL   = input.int(10,    "HTF Pivot Lookback",     group=g_mtf, minval=2, maxval=50)
htfPivotR   = input.int(3,     "HTF Pivot Confirm",      group=g_mtf, minval=1, maxval=10)

g_style     = "Style"
bullColor   = input.color(#00e5a0, "Support Color",    group=g_style)
bearColor   = input.color(#ff4976, "Resistance Color",  group=g_style)
flipColor   = input.color(#ffa500, "Flipped Color",     group=g_style)
showLabels  = input.bool(true, "Show Zone Labels",    group=g_style)

// ──────────────────────────────────────────────────────────────────────────────
// ZONE UDT — NO drawing refs, drawings done separately on barstate.islast
// ──────────────────────────────────────────────────────────────────────────────

type Zone
    float   top
    float   bot
    float   mid
    int     touches
    bool    isBull
    bool    alive
    bool    flipped
    int     birthBar
    bool    isHTF

var Zone[] zones = array.new<Zone>()

atrVal = ta.atr(atrLen)

halfZone(price) =>
    useATRwidth ? atrVal * atrMult : price * fixedWidth / 100.0

// ──────────────────────────────────────────────────────────────────────────────
// ADD ZONES
// ──────────────────────────────────────────────────────────────────────────────

pivHi = ta.pivothigh(high, pivotLeft, pivotRight)
pivLo = ta.pivotlow(low, pivotLeft, pivotRight)

addZone(price, isBull, isHTF) =>
    hw   = halfZone(price)
    _top = price + hw
    _bot = price - hw
    mDist = price * mergeDist / 100.0
    merged = false
    for i = 0 to (array.size(zones) > 0 ? array.size(zones) - 1 : na)
        z = array.get(zones, i)
        if z.alive and z.isBull == isBull and z.isHTF == isHTF
            if math.abs(z.mid - price) / price < mergeDist / 100.0
                z.mid := (z.mid + price) / 2.0
                z.top := z.mid + halfZone(z.mid)
                z.bot := z.mid - halfZone(z.mid)
                merged := true
                break
    if not merged
        array.push(zones, Zone.new(_top, _bot, price, 0, isBull, true, false, bar_index - pivotRight, isHTF))

if not na(pivHi)
    addZone(pivHi, false, false)
if not na(pivLo)
    addZone(pivLo, true, false)

[htfH, htfL, htfC] = request.security(syminfo.tickerid, htfTF, [high, low, close])
htfPivHi = ta.pivothigh(htfH, htfPivotL, htfPivotR)
htfPivLo = ta.pivotlow(htfL, htfPivotL, htfPivotR)
if useMTF and not na(htfPivHi)
    addZone(htfPivHi, false, true)
if useMTF and not na(htfPivLo)
    addZone(htfPivLo, true, true)

// ──────────────────────────────────────────────────────────────────────────────
// TOUCH / FLIP / DEPLETION
// ──────────────────────────────────────────────────────────────────────────────

for i = 0 to (array.size(zones) > 0 ? array.size(zones) - 1 : na)
    z = array.get(zones, i)
    if not z.alive
        continue

    inZone = low <= z.top and high >= z.bot
    wasOut = not (low[1] <= z.top and high[1] >= z.bot)
    if inZone and wasOut
        z.touches += 1

    if z.touches >= maxTouches
        z.alive := false
        continue

    if z.isBull and close < z.bot and close[1] < z.bot
        if not z.flipped
            z.flipped := true
            z.isBull  := false
            z.touches := math.max(0, z.touches - 2)
        else
            z.alive := false
    if not z.isBull and close > z.top and close[1] > z.top
        if not z.flipped
            z.flipped := true
            z.isBull  := true
            z.touches := math.max(0, z.touches - 2)
        else
            z.alive := false

    if bar_index - z.birthBar > hideOld
        z.alive := false

// Prune
aliveCount = 0
for i = 0 to (array.size(zones) > 0 ? array.size(zones) - 1 : na)
    z = array.get(zones, i)
    if z.alive
        aliveCount += 1
if aliveCount > maxZones
    for _kill = 0 to aliveCount - maxZones - 1
        worstIdx = -1
        worstScore = -1.0
        for i = 0 to array.size(zones) - 1
            z = array.get(zones, i)
            if z.alive
                score = z.touches * 1000.0 + (bar_index - z.birthBar)
                if score > worstScore
                    worstScore := score
                    worstIdx   := i
        if worstIdx >= 0
            zKill = array.get(zones, worstIdx)
            zKill.alive := false

// ──────────────────────────────────────────────────────────────────────────────
// DRAWING — same pattern as PulseWave Indicator V1.2
// Lines + linefill, drawn on barstate.islast, using bar_index coordinates
// V1.2 uses: line.new(math.max(bar_index - 5000, 0), mid, bar_index + offset, mid, ...)
// ──────────────────────────────────────────────────────────────────────────────

if barstate.islast
    // Delete all existing drawings
    allLines = line.all
    if array.size(allLines) > 0
        for i = 0 to array.size(allLines) - 1
            line.delete(array.get(allLines, i))
    allLabels = label.all
    if array.size(allLabels) > 0
        for i = 0 to array.size(allLabels) - 1
            label.delete(array.get(allLabels, i))

    for i = 0 to (array.size(zones) > 0 ? array.size(zones) - 1 : na)
        z = array.get(zones, i)
        if not z.alive
            continue

        col    = z.flipped ? flipColor : z.isBull ? bullColor : bearColor
        opac   = 60 + z.touches * 6
        lnCol  = color.new(col, math.min(opac, 85))
        fillOp = z.isHTF ? 82 : 88
        fillCol = color.new(col, fillOp)
        lnW    = z.isHTF ? 2 : 1
        lnS    = z.flipped ? line.style_dashed : line.style_solid

        // Draw two horizontal lines exactly like V1.2 does — bar_index based, long span
        leftX  = math.max(z.birthBar, bar_index - 5000)
        rightX = bar_index + 15

        topLine = line.new(leftX, z.top, rightX, z.top, color=lnCol, width=lnW, style=lnS)
        botLine = line.new(leftX, z.bot, rightX, z.bot, color=lnCol, width=lnW, style=lnS)
        linefill.new(topLine, botLine, fillCol)

        if showLabels
            txt = (z.isBull ? "S " : "R ") + str.tostring(z.touches) + "/" + str.tostring(maxTouches) + (z.isHTF ? " HTF" : "") + (z.flipped ? " ⟲" : "")
            lblCol = color.new(col, 20)
            yP  = z.isBull ? z.bot : z.top
            label.new(rightX + 2, yP, txt, style=z.isBull ? label.style_label_up : label.style_label_down, color=color.new(color.black, 85), textcolor=lblCol, size=size.tiny)

// ──────────────────────────────────────────────────────────────────────────────
// ALERTS
// ──────────────────────────────────────────────────────────────────────────────

nearSup = false
nearRes = false
for i = 0 to (array.size(zones) > 0 ? array.size(zones) - 1 : na)
    z = array.get(zones, i)
    if z.alive
        if z.isBull and low < z.top + atrVal * 1.5 and low > z.bot
            nearSup := true
        if not z.isBull and high > z.bot - atrVal * 1.5 and high < z.top
            nearRes := true

alertcondition(nearSup, "Near Support", "Approaching support")
alertcondition(nearRes, "Near Resistance", "Approaching resistance")

// ──────────────────────────────────────────────────────────────────────────────
// DASHBOARD
// ──────────────────────────────────────────────────────────────────────────────

var table dash = table.new(position.top_right, 2, 3, bgcolor=color.new(#0a0a0c, 10), border_width=1, border_color=color.new(color.white, 90))
if barstate.islast
    aC = 0
    sC = 0
    rC = 0
    for i = 0 to (array.size(zones) > 0 ? array.size(zones) - 1 : na)
        z = array.get(zones, i)
        if z.alive
            aC += 1
            if z.isBull
                sC += 1
            else
                rC += 1
    table.cell(dash, 0, 0, "PW ZONES", text_color=#00e5a0, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 0, str.tostring(aC), text_color=color.white, text_size=size.small)
    table.cell(dash, 0, 1, "S", text_color=color.new(#00e5a0, 30), text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 1, str.tostring(sC), text_color=color.new(#00e5a0, 30), text_size=size.tiny)
    table.cell(dash, 0, 2, "R", text_color=color.new(#ff4976, 30), text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 2, str.tostring(rC), text_color=color.new(#ff4976, 30), text_size=size.tiny)
