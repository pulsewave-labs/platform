// This Pine Script™ code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// © PulseWave Labs
// Hosoda Wave Target Calculator — auto-detects swing structures and projects
// Ichimoku price targets (N, V, E waves) with I/II/III levels

//@version=6
indicator('PulseWave Hosoda', 'PW Hosoda', overlay=true, max_lines_count=500, max_labels_count=500)

// ──────────────────────────────────────────────────────────────
// INPUTS
// ──────────────────────────────────────────────────────────────
g_detect = "Wave Detection"
pivotLen   = input.int(5, "Pivot Length", minval=2, maxval=20, group=g_detect, tooltip="Bars left/right for swing detection. Lower = more waves, higher = stronger swings only.")
minSwing   = input.float(0.3, "Min Swing %", minval=0.1, maxval=5.0, step=0.1, group=g_detect, tooltip="Minimum swing size as % of price to qualify.")
maxWaves   = input.int(3, "Max Active Waves", minval=1, maxval=5, group=g_detect)

g_targets = "Price Targets"
showN      = input.bool(true, "Show N-Wave Target (I)", group=g_targets, tooltip="B + (H - R) — most common target")
showV      = input.bool(true, "Show V-Wave Target (II)", group=g_targets, tooltip="B + (B - R) — symmetrical projection")
showE      = input.bool(true, "Show E-Wave Target (III)", group=g_targets, tooltip="H + (H - R) — extended target")
showNT     = input.bool(false, "Show NT-Wave Target", group=g_targets, tooltip="B + (B - H) — counter-trend target")

g_style = "Style"
bullCol    = input.color(#00e5a0, "Bull Targets", group=g_style)
bearCol    = input.color(#ff4976, "Bear Targets", group=g_style)
waveCol    = input.color(#ffa500, "Wave Lines", group=g_style)
showSwings = input.bool(true, "Show B-H-R Labels", group=g_style)
showWaveLines = input.bool(true, "Show Wave Connector Lines", group=g_style)
targetStyle = input.string("Dots", "Target Style", options=["Dots", "Lines"], group=g_style)
targetExt   = input.int(30, "Target Extension (bars)", minval=5, maxval=100, group=g_style)

// ──────────────────────────────────────────────────────────────
// SWING DETECTION
// ──────────────────────────────────────────────────────────────
pivHi = ta.pivothigh(high, pivotLen, pivotLen)
pivLo = ta.pivotlow(low, pivotLen, pivotLen)

// Track recent swings in order
var float[] swingPrice = array.new_float(0)
var int[]   swingBar   = array.new_int(0)
var bool[]  swingIsHi  = array.new_bool(0)

int MAX_SWINGS = 20

if not na(pivHi)
    float lastLo = float(na)
    if array.size(swingIsHi) > 0
        for i = 0 to array.size(swingIsHi) - 1
            if not array.get(swingIsHi, i)
                lastLo := array.get(swingPrice, i)
                break
    if na(lastLo) or math.abs(pivHi - lastLo) / lastLo * 100 >= minSwing
        if array.size(swingIsHi) > 0 and array.get(swingIsHi, 0)
            if pivHi > array.get(swingPrice, 0)
                array.set(swingPrice, 0, pivHi)
                array.set(swingBar, 0, bar_index - pivotLen)
        else
            array.unshift(swingPrice, pivHi)
            array.unshift(swingBar, bar_index - pivotLen)
            array.unshift(swingIsHi, true)
            if array.size(swingPrice) > MAX_SWINGS
                array.pop(swingPrice)
                array.pop(swingBar)
                array.pop(swingIsHi)

if not na(pivLo)
    float lastHi = float(na)
    if array.size(swingIsHi) > 0
        for i = 0 to array.size(swingIsHi) - 1
            if array.get(swingIsHi, i)
                lastHi := array.get(swingPrice, i)
                break
    if na(lastHi) or math.abs(lastHi - pivLo) / pivLo * 100 >= minSwing
        if array.size(swingIsHi) > 0 and not array.get(swingIsHi, 0)
            if pivLo < array.get(swingPrice, 0)
                array.set(swingPrice, 0, pivLo)
                array.set(swingBar, 0, bar_index - pivotLen)
        else
            array.unshift(swingPrice, pivLo)
            array.unshift(swingBar, bar_index - pivotLen)
            array.unshift(swingIsHi, false)
            if array.size(swingPrice) > MAX_SWINGS
                array.pop(swingPrice)
                array.pop(swingBar)
                array.pop(swingIsHi)

// ──────────────────────────────────────────────────────────────
// HOSODA WAVE PATTERN DETECTION
// B-H-R pattern: Base → High/Low → Return (pullback)
// Bullish: Lo(B) → Hi(H) → Lo(R) → projects UP
// Bearish: Hi(B) → Lo(H) → Hi(R) → projects DOWN
// ──────────────────────────────────────────────────────────────

// Storage for wave drawings
var line[]  waveLines  = array.new_line(0)
var label[] waveLabels = array.new_label(0)
var line[]  targetLines = array.new_line(0)
var label[] targetLabels = array.new_label(0)

// Clean old drawings
if barstate.islast
    for i = 0 to array.size(waveLines) - 1
        line.delete(array.get(waveLines, i))
    for i = 0 to array.size(waveLabels) - 1
        label.delete(array.get(waveLabels, i))
    for i = 0 to array.size(targetLines) - 1
        line.delete(array.get(targetLines, i))
    for i = 0 to array.size(targetLabels) - 1
        label.delete(array.get(targetLabels, i))
    array.clear(waveLines)
    array.clear(waveLabels)
    array.clear(targetLines)
    array.clear(targetLabels)

    int wavesDrawn = 0

    // Need at least 3 swings for B-H-R
    if array.size(swingPrice) >= 3
        // Scan for B-H-R patterns (most recent first)
        // Swings are stored newest-first: [0]=most recent
        for idx = 0 to math.min(array.size(swingPrice) - 3, maxWaves * 2 - 1)
            if wavesDrawn >= maxWaves
                break

            // R = idx, H = idx+1, B = idx+2 (newest to oldest)
            float rPrice = array.get(swingPrice, idx)
            int   rBar   = array.get(swingBar, idx)
            bool  rIsHi  = array.get(swingIsHi, idx)
            float hPrice = array.get(swingPrice, idx + 1)
            int   hBar   = array.get(swingBar, idx + 1)
            bool  hIsHi  = array.get(swingIsHi, idx + 1)
            float bPrice = array.get(swingPrice, idx + 2)
            int   bBar   = array.get(swingBar, idx + 2)
            bool  bIsHi  = array.get(swingIsHi, idx + 2)

            // Bullish wave: B(low) → H(high) → R(low), R > B
            bool isBullWave = not bIsHi and hIsHi and not rIsHi and rPrice > bPrice and hPrice > rPrice
            // Bearish wave: B(high) → H(low) → R(high), R < B
            bool isBearWave = bIsHi and not hIsHi and rIsHi and rPrice < bPrice and hPrice < rPrice

            if isBullWave or isBearWave
                wavesDrawn += 1
                color tCol = isBullWave ? bullCol : bearCol

                // Hosoda wave targets
                float nTarget  = float(na)
                float vTarget  = float(na)
                float eTarget  = float(na)
                float ntTarget = float(na)

                if isBullWave
                    // Bullish: B(low) → H(high) → R(pullback low)
                    nTarget  := rPrice + (hPrice - bPrice)     // I  — N wave
                    vTarget  := hPrice + (hPrice - bPrice)     // II — V wave (2H - B)
                    eTarget  := hPrice + (hPrice - rPrice)     // III — E wave (2H - R)
                    ntTarget := rPrice + (rPrice - bPrice)     // NT wave (2R - B)
                else
                    // Bearish: B(high) → H(low) → R(pullback high)
                    nTarget  := rPrice - (bPrice - hPrice)     // I
                    vTarget  := hPrice - (bPrice - hPrice)     // II
                    eTarget  := hPrice - (rPrice - hPrice)     // III
                    ntTarget := rPrice - (rPrice - bPrice)     // NT

                // Draw B-H-R labels
                if showSwings
                    array.push(waveLabels, label.new(bBar, bPrice, "B", color=color.new(waveCol, 70), textcolor=waveCol, style=isBullWave ? label.style_label_up : label.style_label_down, size=size.small))
                    array.push(waveLabels, label.new(hBar, hPrice, "H", color=color.new(waveCol, 70), textcolor=waveCol, style=isBullWave ? label.style_label_down : label.style_label_up, size=size.small))
                    array.push(waveLabels, label.new(rBar, rPrice, "R", color=color.new(waveCol, 70), textcolor=waveCol, style=isBullWave ? label.style_label_up : label.style_label_down, size=size.small))

                // Draw wave connector lines
                if showWaveLines
                    array.push(waveLines, line.new(bBar, bPrice, hBar, hPrice, color=color.new(waveCol, 40), width=1, style=line.style_solid))
                    array.push(waveLines, line.new(hBar, hPrice, rBar, rPrice, color=color.new(waveCol, 40), width=1, style=line.style_solid))

                // Draw targets
                int tStart = rBar
                int tEnd   = bar_index + targetExt

                if showN and not na(nTarget)
                    if targetStyle == "Lines"
                        array.push(targetLines, line.new(tStart, nTarget, tEnd, nTarget, color=color.new(tCol, 30), width=1, style=line.style_dotted))
                    else
                        // Dots — use circles at the end
                        array.push(targetLines, line.new(tEnd - 3, nTarget, tEnd, nTarget, color=color.new(tCol, 30), width=2, style=line.style_dotted))
                    array.push(targetLabels, label.new(tEnd + 2, nTarget, "I", color=color.new(color.black, 100), textcolor=tCol, style=label.style_none, size=size.normal))

                if showV and not na(vTarget)
                    if targetStyle == "Lines"
                        array.push(targetLines, line.new(tStart, vTarget, tEnd, vTarget, color=color.new(tCol, 30), width=1, style=line.style_dotted))
                    else
                        array.push(targetLines, line.new(tEnd - 3, vTarget, tEnd, vTarget, color=color.new(tCol, 30), width=2, style=line.style_dotted))
                    array.push(targetLabels, label.new(tEnd + 2, vTarget, "II", color=color.new(color.black, 100), textcolor=tCol, style=label.style_none, size=size.normal))

                if showE and not na(eTarget)
                    if targetStyle == "Lines"
                        array.push(targetLines, line.new(tStart, eTarget, tEnd, eTarget, color=color.new(tCol, 30), width=1, style=line.style_dotted))
                    else
                        array.push(targetLines, line.new(tEnd - 3, eTarget, tEnd, eTarget, color=color.new(tCol, 30), width=2, style=line.style_dotted))
                    array.push(targetLabels, label.new(tEnd + 2, eTarget, "III", color=color.new(color.black, 100), textcolor=tCol, style=label.style_none, size=size.normal))

                if showNT and not na(ntTarget)
                    if targetStyle == "Lines"
                        array.push(targetLines, line.new(tStart, ntTarget, tEnd, ntTarget, color=color.new(tCol, 50), width=1, style=line.style_dashed))
                    else
                        array.push(targetLines, line.new(tEnd - 3, ntTarget, tEnd, ntTarget, color=color.new(tCol, 50), width=2, style=line.style_dashed))
                    array.push(targetLabels, label.new(tEnd + 2, ntTarget, "NT", color=color.new(color.black, 100), textcolor=color.new(tCol, 30), style=label.style_none, size=size.small))

// ──────────────────────────────────────────────────────────────
// DASHBOARD
// ──────────────────────────────────────────────────────────────
var table dash = table.new(position.top_right, 2, 2, bgcolor=color.new(#0a0a0c, 10), border_width=1, border_color=color.new(color.white, 90))
if barstate.islast
    table.cell(dash, 0, 0, "HOSODA", text_color=#ffa500, text_size=size.small, text_halign=text.align_left)
    table.cell(dash, 1, 0, "WAVES", text_color=color.new(color.white, 40), text_size=size.small)
    swingCount = array.size(swingPrice)
    table.cell(dash, 0, 1, "Swings", text_color=color.new(color.white, 50), text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash, 1, 1, str.tostring(swingCount), text_color=color.new(color.white, 50), text_size=size.tiny)

// ──────────────────────────────────────────────────────────────
// ALERTS
// ──────────────────────────────────────────────────────────────
alertcondition(not na(pivHi) or not na(pivLo), title="New Swing Detected", message="New swing point on {{ticker}} ({{interval}})")
