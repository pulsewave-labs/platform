// This Pine Script™ code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// © PulseWave Labs
// Squeeze Momentum Oscillator — BB squeeze detection + momentum histogram
// Inspired by John Carter's TTM Squeeze

//@version=6
indicator('PulseWave Squeeze', 'PW Squeeze', false)

// ──────────────────────────────────────────────────────────────
// INPUTS
// ──────────────────────────────────────────────────────────────
g_squeeze = "Squeeze Detection"
bbLen    = input.int(20, "BB Length", minval=5, maxval=50, group=g_squeeze)
bbMult   = input.float(2.0, "BB Multiplier", minval=0.5, maxval=4.0, step=0.5, group=g_squeeze)
kcLen    = input.int(20, "KC Length", minval=5, maxval=50, group=g_squeeze)
kcMult   = input.float(1.5, "KC Multiplier", minval=0.5, maxval=4.0, step=0.5, group=g_squeeze)

g_momentum = "Momentum"
momLen   = input.int(12, "Momentum Length", minval=4, maxval=30, group=g_momentum)
momSrc   = input.source(close, "Source", group=g_momentum)

g_style = "Style"
bullUp   = input.color(#00e5a0, "Bull Increasing", group=g_style)
bullDn   = input.color(color.rgb(0, 140, 100), "Bull Decreasing", group=g_style)
bearDn   = input.color(#ff4976, "Bear Increasing", group=g_style)
bearUp   = input.color(color.rgb(180, 60, 80), "Bear Decreasing", group=g_style)
sqzOnCol = input.color(#ff4976, "Squeeze On (dots)", group=g_style)
sqzOffCol = input.color(#00e5a0, "Squeeze Off (dots)", group=g_style)
noSqzCol = input.color(color.rgb(100, 100, 100), "No Squeeze (dots)", group=g_style)

// ──────────────────────────────────────────────────────────────
// BOLLINGER BANDS
// ──────────────────────────────────────────────────────────────
bbBasis = ta.sma(momSrc, bbLen)
bbDev   = bbMult * ta.stdev(momSrc, bbLen)
bbUpper = bbBasis + bbDev
bbLower = bbBasis - bbDev

// ──────────────────────────────────────────────────────────────
// KELTNER CHANNELS
// ──────────────────────────────────────────────────────────────
kcBasis = ta.sma(momSrc, kcLen)
kcRange = ta.atr(kcLen)
kcUpper = kcBasis + kcRange * kcMult
kcLower = kcBasis - kcRange * kcMult

// ──────────────────────────────────────────────────────────────
// SQUEEZE STATE
// ──────────────────────────────────────────────────────────────
sqzOn  = bbLower > kcLower and bbUpper < kcUpper  // BB inside KC = squeeze
sqzOff = bbLower < kcLower and bbUpper > kcUpper  // BB outside KC = expansion
noSqz  = not sqzOn and not sqzOff

// Squeeze just fired (released)
sqzFired = sqzOff and sqzOn[1]

// ──────────────────────────────────────────────────────────────
// MOMENTUM — Linear Regression of (close - avg(highest, lowest, sma))
// ──────────────────────────────────────────────────────────────
float hl2Mid = (ta.highest(high, momLen) + ta.lowest(low, momLen)) / 2
float momVal = ta.linreg(momSrc - (hl2Mid + ta.sma(momSrc, momLen)) / 2, momLen, 0)

// Color: green shades when positive, red shades when negative
// Brighter when increasing magnitude, darker when decreasing
color momColor = momVal > 0 ? (momVal > momVal[1] ? bullUp : bullDn) : (momVal < momVal[1] ? bearDn : bearUp)

// ──────────────────────────────────────────────────────────────
// PLOTS
// ──────────────────────────────────────────────────────────────
// Momentum histogram
plot(momVal, "Momentum", momColor, style=plot.style_columns)

// Zero line
hline(0, "Zero", color.new(color.white, 80), hline.style_dotted)

// Squeeze dots on zero line
color sqzColor = sqzOn ? sqzOnCol : sqzOff ? sqzOffCol : noSqzCol
plot(0, "Squeeze", sqzColor, 4, plot.style_circles)

// ──────────────────────────────────────────────────────────────
// SIGNAL LINE (optional smoothed momentum)
// ──────────────────────────────────────────────────────────────
sigLen  = input.int(5, "Signal Line Length", minval=2, maxval=15, group=g_momentum)
showSig = input.bool(true, "Show Signal Line", group=g_momentum)
sigVal  = ta.sma(momVal, sigLen)
plot(showSig ? sigVal : na, "Signal", color.new(color.white, 40), 1)

// ──────────────────────────────────────────────────────────────
// ALERTS
// ──────────────────────────────────────────────────────────────
alertcondition(sqzFired, title="Squeeze Fired", message="🔥 Squeeze fired on {{ticker}} ({{interval}})")
alertcondition(sqzFired and momVal > 0, title="Bull Squeeze", message="🟢 Bullish squeeze fire on {{ticker}} ({{interval}})")
alertcondition(sqzFired and momVal < 0, title="Bear Squeeze", message="🔴 Bearish squeeze fire on {{ticker}} ({{interval}})")
alertcondition(ta.crossover(momVal, 0), title="Momentum Bull Cross", message="Momentum crossed bullish on {{ticker}}")
alertcondition(ta.crossunder(momVal, 0), title="Momentum Bear Cross", message="Momentum crossed bearish on {{ticker}}")
